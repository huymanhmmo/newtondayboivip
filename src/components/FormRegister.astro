---
interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "ĐĂNG KÝ TƯ VẤN HỌC BƠI", 
  subtitle = "Điền thông tin bên dưới, CanSwim sẽ liên hệ tư vấn lịch học phù hợp nhất cho bé hoặc bạn trong vòng 15 phút." 
} = Astro.props;

// Sử dụng Access Key mặc định của Web3Forms.
// Người dùng có thể lấy key miễn phí tại https://web3forms.com và thay thế ở đây hoặc qua biến môi trường.
const web3formsAccessKey = "d8787c88-e215-4ba2-bed2-3510c5a2c41c"; // Đây là khóa demo công khai hoặc người dùng sẽ điền key của họ.
---

<div class="registration-form-wrapper glass-card">
  <div class="form-header text-center">
    <h3 class="form-title">{title}</h3>
    <p class="form-subtitle">{subtitle}</p>
  </div>

  <form action="https://api.web3forms.com/submit" method="POST" id="swimRegisterForm" class="swim-form">
    <!-- Web3Forms Configuration -->
    <input type="hidden" name="access_key" value={web3formsAccessKey} />
    <input type="hidden" name="subject" value="Đăng ký học bơi mới từ newton.dayboi.vip" />
    <input type="hidden" name="from_name" value="CanSwim Bể bơi Newton" />
    <input type="hidden" name="replyto" value="dayboivip@gmail.com" />
    <!-- Bot Protection -->
    <input type="checkbox" name="botcheck" class="botcheck-field" style="display: none;" />

    <div class="form-group">
      <label for="fullName" class="form-label">Họ và tên *</label>
      <input type="text" id="fullName" name="name" class="form-input" placeholder="Nhập họ và tên phụ huynh hoặc học viên" required />
    </div>

    <div class="form-group">
      <label for="phoneNumber" class="form-label">Số điện thoại *</label>
      <input type="tel" id="phoneNumber" name="phone" class="form-input" placeholder="Nhập số điện thoại liên hệ" required />
    </div>

    <div class="form-grid">
      <div class="form-group">
        <label for="ageGroup" class="form-label">Độ tuổi học viên *</label>
        <select id="ageGroup" name="age_group" class="form-input" required>
          <option value="" disabled selected>Chọn độ tuổi</option>
          <option value="Dưới 5 tuổi">Dưới 5 tuổi</option>
          <option value="Từ 5 - 10 tuổi">Từ 5 - 10 tuổi (Trẻ em)</option>
          <option value="Từ 11 - 15 tuổi">Từ 11 - 15 tuổi (Thiếu niên)</option>
          <option value="Trên 15 tuổi / Người lớn">Người lớn</option>
        </select>
      </div>

      <div class="form-group">
        <label for="interestedCourse" class="form-label">Khóa học quan tâm *</label>
        <select id="interestedCourse" name="course" class="form-input" required>
          <option value="" disabled selected>Chọn khóa học</option>
          <option value="Bơi ếch">Khóa Bơi Ếch</option>
          <option value="Bơi sải">Khóa Bơi Sải</option>
          <option value="Bơi ngửa">Khóa Bơi Ngửa</option>
          <option value="Bơi bướm">Khóa Bơi Bướm</option>
          <option value="Combo Ếch + Sải">Gói Combo Ếch + Sải (15 vé)</option>
          <option value="Chưa quyết định / Cần tư vấn">Tôi cần tư vấn thêm</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label for="notes" class="form-label">Ghi chú yêu cầu đặc biệt (nếu có)</label>
      <textarea id="notes" name="message" class="form-input form-textarea" rows="3" placeholder="Nhập khung giờ mong muốn học, tình trạng nhát nước của bé,..."></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-submit-form" id="submitBtn">
      <span>GỬI THÔNG TIN ĐĂNG KÝ</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="send-icon"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </form>

  <!-- Success/Error Message Popup Overlay -->
  <div class="form-status-overlay" id="formStatusOverlay">
    <div class="status-card glass-card text-center">
      <div class="status-icon success-icon" id="successIcon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="status-icon error-icon" id="errorIcon" style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </div>
      <h4 class="status-title" id="statusTitle">Đăng ký thành công!</h4>
      <p class="status-message" id="statusMessage">Cảm ơn bạn đã để lại thông tin. CanSwim sẽ liên hệ với bạn trong thời gian sớm nhất qua số điện thoại đã cung cấp.</p>
      <button class="btn btn-secondary btn-status-close" id="statusCloseBtn">Đóng</button>
    </div>
  </div>
</div>

<style>
  .registration-form-wrapper {
    position: relative;
    overflow: hidden;
  }

  .form-header {
    margin-bottom: 25px;
  }

  .form-title {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .form-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-textarea {
    resize: vertical;
  }

  .btn-submit-form {
    width: 100%;
    margin-top: 10px;
    padding: 16px;
    border-radius: 12px;
  }

  .send-icon {
    width: 18px;
    height: 18px;
    transition: transform var(--transition-fast);
  }

  .btn-submit-form:hover .send-icon {
    transform: translate(2px, -2px);
  }

  /* Form Submission Status CSS Overlay */
  .form-status-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-normal);
    z-index: 10;
  }

  .form-status-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .status-card {
    max-width: 90%;
    width: 380px;
    transform: translateY(20px);
    transition: transform var(--transition-normal);
  }

  .form-status-overlay.active .status-card {
    transform: translateY(0);
  }

  .status-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto 20px auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-icon {
    background-color: rgba(46, 204, 113, 0.15);
    color: #2ecc71;
  }

  .error-icon {
    background-color: rgba(231, 76, 60, 0.15);
    color: #e74c3c;
  }

  .status-icon svg {
    width: 28px;
    height: 28px;
  }

  .status-title {
    font-size: 1.3rem;
    margin-bottom: 10px;
  }

  .status-message {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .btn-status-close {
    width: 100%;
    padding: 12px;
  }

  @media (max-width: 576px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>

<script>
  const form = document.getElementById('swimRegisterForm') as HTMLFormElement;
  const overlay = document.getElementById('formStatusOverlay');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const successIcon = document.getElementById('successIcon');
  const errorIcon = document.getElementById('errorIcon');
  const statusTitle = document.getElementById('statusTitle');
  const statusMessage = document.getElementById('statusMessage');
  const closeBtn = document.getElementById('statusCloseBtn');

  if (form && overlay && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Disable button and show loading status
      submitBtn.disabled = true;
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = '<span>Đang gửi thông tin...</span>';

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: json
        });

        const result = await response.json();

        if (response.status === 200 && result.success) {
          // Success
          if (successIcon) successIcon.style.display = 'flex';
          if (errorIcon) errorIcon.style.display = 'none';
          if (statusTitle) statusTitle.textContent = 'Đăng ký thành công!';
          if (statusMessage) statusMessage.textContent = 'Cảm ơn bạn đã để lại thông tin học bơi. CanSwim sẽ liên hệ lại với bạn trong vòng 15 phút để tư vấn lịch học phù hợp nhất!';
          
          form.reset();
        } else {
          // Response error
          throw new Error(result.message || 'Có lỗi xảy ra');
        }
      } catch (error: any) {
        // Network/parsing error
        if (successIcon) successIcon.style.display = 'none';
        if (errorIcon) errorIcon.style.display = 'flex';
        if (statusTitle) statusTitle.textContent = 'Có lỗi xảy ra!';
        if (statusMessage) statusMessage.textContent = error.message || 'Không thể kết nối đến hệ thống đăng ký. Vui lòng liên hệ trực tiếp hotline 0907.992.336 để được hỗ trợ đăng ký nhanh nhất.';
      } finally {
        // Restore submit button state
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
        
        // Show status overlay
        overlay.classList.add('active');
      }
    });
  }

  // Close overlay button event
  if (closeBtn && overlay) {
    closeBtn.addEventListener('click', () => {
      overlay.classList.remove('active');
    });
  }
</script>
