---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  schemaType?: 'WebSite' | 'LocalBusiness' | 'FAQPage' | 'Article';
  customSchema?: any;
}

const { 
  title, 
  description, 
  image,
  canonicalURL = Astro.url.href, 
  schemaType = 'WebSite',
  customSchema 
} = Astro.props;

// Phân loại hình ảnh phù hợp mạng xã hội theo kích thước:
// banner-tuyen-sinh-1.png: 1734 x 907 (tỷ lệ 1.91:1) -> Đẹp nhất cho Facebook, Zalo, LinkedIn link sharing
// banner-tuyen-sinh-3.png: 1734 x 907 (tỷ lệ 1.91:1) -> Đẹp nhất cho Twitter
// banner-tuyen-sinh-2.png: 1536 x 1024 (tỷ lệ 3:2) -> Phù hợp cho chia sẻ dạng hình ảnh ngang
// banner-tuyen-sinh-4.png: 1536 x 1024 (tỷ lệ 3:2) -> Phù hợp cho chia sẻ dạng hình ảnh ngang
const ogImage = image || "https://newton.dayboi.vip/images/banner-tuyen-sinh-1.png";
const twitterImage = image || "https://newton.dayboi.vip/images/banner-tuyen-sinh-3.png";

// Tự động phân loại kích thước và định dạng tương thích cho meta tags
let ogWidth = "1734";
let ogHeight = "907";
let ogType = "image/png";

if (image) {
  if (image.includes("banner-tuyen-sinh-2") || image.includes("banner-tuyen-sinh-4")) {
    ogWidth = "1536";
    ogHeight = "1024";
    ogType = "image/png";
  } else if (image.includes("banner-tuyen-sinh-1") || image.includes("banner-tuyen-sinh-3")) {
    ogWidth = "1734";
    ogHeight = "907";
    ogType = "image/png";
  } else {
    // Giá trị fallback an toàn
    ogWidth = "1200";
    ogHeight = "630";
    ogType = "image/jpeg";
  }
}

// Schema mặc định của LocalBusiness
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  "name": "Trung tâm dạy bơi CanSwim tại Bể bơi Newton",
  "alternateName": "CanSwim Bể bơi Newton Cầu Giấy",
  "url": "https://newton.dayboi.vip",
  "logo": "https://newton.dayboi.vip/logo.png",
  "image": ogImage,
  "description": description || "Lớp học bơi trẻ em và người lớn uy tín tại bể bơi Newton, ngõ 234 Hoàng Quốc Việt, Nghĩa Đô, Cầu Giấy, Hà Nội.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bể bơi Newton, khu Trường Newton, lô TH2 khu đô thị Nam Cường, cuối ngõ 234 Hoàng Quốc Việt, phường Nghĩa Đô",
    "addressLocality": "Cầu Giấy",
    "addressRegion": "Hà Nội",
    "postalCode": "100000",
    "addressCountry": "VN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "21.047464", // Tọa độ tương đối khu trường Newton Hoàng Quốc Việt
    "longitude": "105.792557"
  },
  "telephone": "0907992336",
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "16:00",
      "closes": "20:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Saturday", "Sunday"],
      "opens": "15:00",
      "closes": "20:30"
    }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "0907992336",
    "contactType": "customer service",
    "areaServed": ["HN", "Cầu Giấy", "Bắc Từ Liêm"],
    "availableLanguage": "Vietnamese"
  },
  "sameAs": [
    "https://www.facebook.com/beboinewton"
  ]
};

// Website Schema mặc định
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Trung tâm dạy bơi CanSwim tại Bể bơi Newton",
  "url": "https://newton.dayboi.vip"
};

const activeSchema = customSchema 
  ? customSchema 
  : (schemaType === 'LocalBusiness' ? localBusinessSchema : websiteSchema);
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook / Zalo / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={ogWidth} />
    <meta property="og:image:height" content={ogHeight} />
    <meta property="og:image:type" content={ogType} />
    <meta property="og:site_name" content="CanSwim - Dạy bơi bể bơi Newton" />
    <meta property="og:locale" content="vi_VN" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImage} />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(activeSchema)} />

    <!-- Prefetch for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-74CCVG5VNC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-74CCVG5VNC');
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
