<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Tự động tạo danh sách mục lục (TOC)
    const headings = document.querySelectorAll('.markdown-body h2, .markdown-body h3');
    const tocList = document.getElementById('toc-list');
    
    if (!tocList) return;
    
    if (headings.length === 0) {
      tocList.innerHTML = '<li class="toc-item"><span class="no-toc-data" style="font-size: 0.82rem; color: var(--color-text-muted); font-style: italic;">Không có đề mục lớn</span></li>';
      return;
    }

    headings.forEach((heading, index) => {
      // Đặt ID cho thẻ nếu chưa có
      if (!heading.id) {
        const rawText = heading.textContent || '';
        const safeId = 'muc-' + rawText.toLowerCase()
          .replace(/[áàảãạăắằẳẵặâấầẩẫậ]/g, 'a')
          .replace(/[éèẻẽẹêếềểễệ]/g, 'e')
          .replace(/[íìỉĩị]/g, 'i')
          .replace(/[óòỏõọôốồổỗộơớờởỡợ]/g, 'o')
          .replace(/[úùủũụưứừửữự]/g, 'u')
          .replace(/[ýỳỷỹỵ]/g, 'y')
          .replace(/đ/g, 'd')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '') || 'de-muc-' + index;
          
        heading.id = safeId;
      }

      // Tạo thẻ li và a tương ứng
      const li = document.createElement('li');
      li.className = heading.tagName.toLowerCase() === 'h2' ? 'toc-item h2-item' : 'toc-item h3-item';
      
      const a = document.createElement('a');
      a.href = '#' + heading.id;
      a.textContent = heading.textContent;
      
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // 2. Scrollspy - Highlight mục lục tương ứng khi cuộn trang
    const observerOptions = {
      root: null,
      rootMargin: '-100px 0px -75%',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          document.querySelectorAll('.toc-item').forEach(item => {
            const link = item.querySelector('a');
            if (link && link.getAttribute('href') === '#' + id) {
              item.classList.add('active');
            } else {
              item.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach(heading => observer.observe(heading));

    // 3. Đồng bộ cuộn hai chiều giữa trang bài viết và danh sách mục lục (toc-list)
    let activeScrollSource = null;
    let scrollTimeout;

    // Khi cuộn trang bài viết chính -> cuộn TOC tương ứng
    window.addEventListener('scroll', () => {
      if (activeScrollSource === 'toc') return;
      activeScrollSource = 'page';

      const maxPageScroll = document.documentElement.scrollHeight - window.innerHeight;
      if (maxPageScroll > 0) {
        const ratio = window.scrollY / maxPageScroll;
        const maxTocScroll = tocList.scrollHeight - tocList.clientHeight;
        tocList.scrollTop = ratio * maxTocScroll;
      }

      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        activeScrollSource = null;
      }, 50);
    });

    // Khi cuộn trực tiếp trên TOC -> cuộn trang bài viết chính tương ứng
    tocList.addEventListener('scroll', () => {
      if (activeScrollSource === 'page') return;
      activeScrollSource = 'toc';

      const maxTocScroll = tocList.scrollHeight - tocList.clientHeight;
      if (maxTocScroll > 0) {
        const ratio = tocList.scrollTop / maxTocScroll;
        const maxPageScroll = document.documentElement.scrollHeight - window.innerHeight;
        window.scrollTo(0, ratio * maxPageScroll);
      }

      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        activeScrollSource = null;
      }, 50);
    });
  });
</script>
