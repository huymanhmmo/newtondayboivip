---
import { getCollection, render } from 'astro:content';

import Layout from '../../layouts/Layout.astro';

// 1. Tạo static paths cho toàn bộ các bài viết
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Lấy dữ liệu bài viết từ props
const { entry } = Astro.props;
const { title, description, pubDate, image, tags } = entry.data;
const { Content } = await render(entry);

const formattedDate = new Date(pubDate).toLocaleDateString('vi-VN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Cấu hình Article Schema động cho SEO Google News/AI search
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": image ? `https://newton.dayboi.vip${image}` : "https://newton.dayboi.vip/images/banner-tuyen-sinh-1.png",
  "datePublished": pubDate.toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "CanSwim Bể bơi Newton"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Trung tâm dạy bơi CanSwim",
    "logo": {
      "@type": "ImageObject",
      "url": "https://newton.dayboi.vip/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://newton.dayboi.vip/cam-nang/${entry.id}`
  }
};

// Lấy danh sách các bài viết mới nhất (tối đa 10 bài, loại trừ bài hiện tại)
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(post => post.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

// Lấy danh sách bài viết liên quan (tối đa 8 bài, ưu tiên cùng tags, loại trừ bài hiện tại)
const relatedPosts = allPosts
  .filter(post => post.id !== entry.id)
  .sort((a, b) => {
    const aSharedTags = a.data.tags ? a.data.tags.filter(t => tags?.includes(t)).length : 0;
    const bSharedTags = b.data.tags ? b.data.tags.filter(t => tags?.includes(t)).length : 0;
    if (aSharedTags !== bSharedTags) {
      return bSharedTags - aSharedTags;
    }
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 8);
---

<Layout 
  title={`${title} | Tin Tức CanSwim`}
  description={description}
  schemaType="Article"
  customSchema={articleSchema}
>
  <article class="blog-post-detail-section">
    <!-- Header: 1 Row, 2 Columns Layout -->
    <header class="post-header-top">
      <div class="container max-width-post-header-grid">
        <div class="post-header-grid">
          <!-- Left Column: Back Link, Meta, Title, Description -->
          <div class="post-header-left">
            <a href="/cam-nang" class="back-to-blog">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-back-icon" width="16" height="16"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              <span>Quay lại Cẩm nang</span>
            </a>
            
            <div class="post-meta">
              <span class="post-date-span">{formattedDate}</span>
              {tags && tags.map(tag => (
                <span class="tag-badge-span">#{tag}</span>
              ))}
            </div>

            <h1 class="post-title-heading">{title}</h1>
            <p class="post-lead-desc">{description}</p>
          </div>

          <!-- Right Column: Full Cover Image -->
          <div class="post-header-right">
            {image && (
              <div class="post-cover-img-wrapper">
                <img src={image} alt={title} class="post-cover-img" width="1000" height="667" loading="eager" fetchpriority="high" />
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- 3-Column Layout -->
    <div class="container max-width-post-layout-3cols">
      <div class="post-layout-grid-3cols">
        <!-- LEFT COLUMN: Table of Contents (20%) -->
        <aside class="post-sidebar-left">
          <div class="sidebar-sticky-wrapper">
            <nav class="toc-box glass-card">
              <h4>MỤC LỤC CHI TIẾT</h4>
              <ul class="toc-list" id="toc-list">
                <!-- Dynamically generated by Scrollspy script -->
              </ul>
            </nav>
          </div>
        </aside>

        <!-- MIDDLE COLUMN: Content (60%) -->
        <div class="post-main-content">
          <div class="markdown-body">
            <Content />
          </div>

          <div class="post-footer-cta glass-card">
            <h4>Đăng Ký Học Bơi Tại Bể Bơi Newton Hôm Nay!</h4>
            <p>Đội ngũ HLV CanSwim chuyên nghiệp trực tiếp kèm sát 1-1 hoặc nhóm nhỏ cam kết chất lượng đầu ra bài bản, đúng kỹ thuật và rèn luyện thể chất toàn diện.</p>
            <div class="post-cta-buttons">
              <a href="/lien-he#register" class="btn btn-primary">ĐĂNG KÝ NGAY</a>
              <a href="tel:0907992336" class="btn btn-secondary">HOTLINE: 0907.992.336</a>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Widgets (20%) -->
        <aside class="post-sidebar-right">
          <div class="sidebar-sticky-wrapper">
            <!-- Widget 1: Recent Posts (Max 10) -->
            {recentPosts.length > 0 && (
              <div class="sidebar-box glass-card recent-posts-box">
                <h4>Bài Viết Mới Nhất</h4>
                <ul class="recent-posts-list">
                  {recentPosts.map(post => (
                    <li>
                      <a href={`/cam-nang/${post.id}`} class="recent-post-link-card">
                        {post.data.image && (
                          <div class="recent-post-thumb-wrapper">
                            <img src={post.data.image} alt={post.data.title} class="recent-post-thumb" loading="lazy" />
                          </div>
                        )}
                        <span class="recent-post-title-text">{post.data.title}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Widget 2: Course Consultation Form -->
            <div class="sidebar-box glass-card quick-register-box">
              <h4>Tư Vấn Khóa Học</h4>
              <p>Đặt lịch kiểm tra trình độ bơi lội miễn phí cho bé và nhận ưu đãi tốt nhất.</p>
              <a href="/lien-he#register" class="btn btn-primary sidebar-btn-register">GỬI THÔNG TIN</a>
            </div>

            <!-- Widget 3: Support Info -->
            <div class="sidebar-box glass-card contact-box-sidebar">
              <h4>Thông Tin Hỗ Trợ</h4>
              <p><strong>Hotline:</strong> 0907.992.336</p>
              <p><strong>Zalo:</strong> <a href="http://zalo.me/0907992336" target="_blank" rel="noopener noreferrer">0907 992 336</a></p>
              <p><strong>Địa chỉ:</strong> Bể bơi Newton, cuối ngõ 234 Hoàng Quốc Việt, Cầu Giấy, HN</p>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <!-- Related Posts Section (Bài viết liên quan - 100% width, 2 rows x 4 cols grid) -->
    {relatedPosts.length > 0 && (
      <section class="related-posts-section">
        <div class="container max-width-related-posts">
          <div class="section-header-related">
            <h3 class="related-section-title">Bài Viết Liên Quan</h3>
          </div>
          <div class="related-posts-grid-4cols">
            {relatedPosts.map(post => (
              <article class="related-post-card glass-card">
                <a href={`/cam-nang/${post.id}`} class="related-post-card-link">
                  {post.data.image && (
                    <div class="related-post-card-img-wrapper">
                      <img src={post.data.image} alt={post.data.title} class="related-post-card-img" loading="lazy" />
                    </div>
                  )}
                  <div class="related-post-card-info">
                    <h4 class="related-post-card-title">{post.data.title}</h4>
                    <p class="related-post-card-desc">{post.data.description}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .blog-post-detail-section {
    background-color: var(--color-bg);
  }

  /* Header Top Area (1 Row, 2 Columns) */
  .post-header-top {
    padding-top: 140px;
    padding-bottom: 60px;
    background-color: var(--color-bg);
    position: relative;
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: 50px;
    overflow: hidden; /* Prevent background glow from causing horizontal overflow */
  }
  
  /* Soft background glow for the article header */
  .post-header-top::before {
    content: '';
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 102, 170, 0.06) 0%, rgba(255, 255, 255, 0) 70%);
    z-index: 1;
    pointer-events: none;
  }

  .max-width-post-header-grid {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding-left: 30px;
    padding-right: 30px;
  }

  .post-header-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 50px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .post-header-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    min-width: 0; /* Prevent flex children from stretching container horizontally */
  }

  .post-header-right {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 24px;
    position: relative;
    z-index: 2;
    transition: transform var(--transition-fast);
  }

  .back-to-blog:hover {
    color: var(--color-primary-light);
    transform: translateX(-4px);
  }

  .post-meta {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
    overflow-x: auto;
    white-space: nowrap;
    width: 100%;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    padding-bottom: 8px; /* Avoid cutting off letters and descenders */
    -webkit-overflow-scrolling: touch;
  }

  .post-meta::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .post-date-span {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .post-date-span::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    flex-shrink: 0;
  }

  .tag-badge-span {
    background-color: var(--color-primary-glare);
    color: var(--color-primary);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    transition: all var(--transition-fast);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .tag-badge-span:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .post-title-heading {
    font-size: 3.2rem;
    line-height: 1.25;
    font-weight: 800;
    color: var(--color-primary);
    margin-top: 15px;
    margin-bottom: 24px;
    letter-spacing: -0.8px;
    font-family: var(--font-heading);
    position: relative;
    z-index: 2;
    text-align: left;
    background: linear-gradient(135deg, var(--color-primary-dark) 30%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: normal !important;
    word-break: break-word;
  }

  .post-lead-desc {
    font-size: 1.25rem;
    color: var(--color-text);
    font-weight: 700;
    line-height: 1.8;
    max-width: 850px;
    margin: 24px 0 0 0;
    padding: 24px 30px;
    border-left: 6px solid var(--color-secondary);
    background: linear-gradient(135deg, var(--color-primary-glare) 0%, rgba(255, 255, 255, 0.8) 100%);
    backdrop-filter: blur(8px);
    border-radius: 0 20px 20px 0;
    text-align: left;
    box-shadow: 0 8px 30px rgba(0, 50, 100, 0.04);
    position: relative;
    z-index: 2;
    font-style: italic;
  }

  /* Cover image displaying 100% full content */
  .post-cover-img-wrapper {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--glass-border);
    width: 100%;
    height: auto;
    background-color: var(--color-white);
    transition: transform var(--transition-slow);
  }

  .post-cover-img-wrapper:hover {
    transform: scale(1.005);
  }

  .post-cover-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* 3-Column layout configuration */
  .max-width-post-layout-3cols {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding-left: 30px;
    padding-right: 30px;
    margin-bottom: 60px;
  }

  .post-layout-grid-3cols {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 6fr) minmax(0, 2fr);
    gap: 40px;
    align-items: flex-start;
  }

  /* Left sidebar - TOC (20%) */
  .post-sidebar-left {
    position: sticky;
    top: 100px;
    align-self: start;
    max-height: calc(100vh - 120px);
    display: flex;
    flex-direction: column;
  }

  /* Right sidebar - Widgets (20%) */
  .post-sidebar-right {
    position: sticky;
    top: 100px;
    align-self: start;
    height: auto;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    scrollbar-width: none;
    padding-bottom: 20px;
  }

  .post-sidebar-right::-webkit-scrollbar {
    display: none;
  }

  .sidebar-sticky-wrapper {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-height: 100%;
  }

  /* TOC styling */
  .toc-box {
    padding: 24px;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 140px);
    overflow: hidden;
  }

  .toc-box h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 20px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 10px;
    flex-shrink: 0;
  }

  .toc-list {
    list-style: none;
    padding-left: 16px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-left: 1px solid rgba(0, 102, 170, 0.1);
    position: relative;
    overflow-y: auto;
    flex-grow: 1;
    padding-right: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary-light) rgba(0, 102, 170, 0.05);
  }

  .toc-list::-webkit-scrollbar {
    width: 6px;
  }

  .toc-list::-webkit-scrollbar-track {
    background: rgba(0, 102, 170, 0.05);
    border-radius: 3px;
  }

  .toc-list::-webkit-scrollbar-thumb {
    background: var(--color-primary-light);
    border-radius: 3px;
  }

  .toc-list::-webkit-scrollbar-thumb:hover {
    background: var(--color-primary);
  }

  .toc-item {
    position: relative;
  }

  .toc-item a {
    color: var(--color-text-muted);
    font-size: 0.8rem; /* Slightly smaller size */
    line-height: 1.4;
    transition: all var(--transition-fast);
    display: block;
    text-decoration: none !important;
    border-bottom: none !important; /* Ensure no underlines inherited globally */
    font-weight: 400; /* Normal weight by default */
  }

  .toc-item.h2-item a {
    font-weight: 500; /* Medium weight for H2 sections, not too heavy */
  }

  .toc-item.h3-item {
    padding-left: 12px;
  }

  .toc-item:hover a {
    color: var(--color-primary);
    text-decoration: none !important;
    border-bottom: none !important;
  }

  .toc-item.active a {
    color: var(--color-primary);
    font-weight: 600; /* Active item is semi-bold, clean */
    text-decoration: none !important;
    border-bottom: none !important;
  }

  /* Active marker at the track line */
  .toc-item.active::before {
    content: '';
    position: absolute;
    left: -18px; /* aligns exactly with the border-left line of .toc-list */
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 16px;
    background-color: var(--color-secondary);
    border-radius: 2px;
  }

  /* Recent Posts Widget */
  .recent-posts-box {
    padding: 24px;
    border-radius: 20px;
  }

  .recent-posts-box h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 20px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 10px;
  }

  .recent-posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .recent-posts-list li {
    border-bottom: 1px dashed var(--glass-border);
    padding-bottom: 12px;
  }

  .recent-posts-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* New thumbnail layout for recent posts */
  .recent-post-link-card {
    display: flex;
    gap: 12px;
    align-items: center;
    text-decoration: none;
    width: 100%;
  }

  .recent-post-thumb-wrapper {
    width: 65px;
    height: 48px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-sm);
    background-color: var(--color-white);
  }

  .recent-post-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .recent-post-link-card:hover .recent-post-thumb {
    transform: scale(1.05);
  }

  .recent-post-title-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    transition: color var(--transition-fast);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-post-link-card:hover .recent-post-title-text {
    color: var(--color-primary);
  }

  /* Markdown body render */
  .markdown-body {
    line-height: 1.9;
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 50px;
    word-wrap: break-word;
    word-break: break-word;
    overflow-wrap: break-word;
    text-align: justify; /* Justify text align */
  }

  .markdown-body :global(a) {
    color: var(--color-primary);
    font-weight: 700;
    border-bottom: 2px solid var(--color-secondary); /* Accent orange underline */
    padding: 0 2px;
    text-decoration: none;
    transition: all var(--transition-fast);
    display: inline;
  }

  .markdown-body :global(a:hover) {
    color: var(--color-white) !important;
    background-color: var(--color-secondary); /* Vibrant orange highlight background */
    border-bottom-color: var(--color-secondary);
    border-radius: 4px;
    padding: 2px 6px;
    margin: -2px -4px; /* Perfectly balances padding to prevent layout shifts */
    box-shadow: 0 4px 10px rgba(255, 122, 0, 0.25);
    text-decoration: none;
  }

  .markdown-body :global(p) {
    margin-bottom: 24px;
  }

  .markdown-body :global(h2) {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-top: 45px;
    margin-bottom: 20px;
    font-weight: 700;
    scroll-margin-top: 100px; /* Offset for sticky header when jumping from TOC */
    border-bottom: 1px solid var(--color-primary-glare);
    padding-bottom: 8px;
  }

  .markdown-body :global(h3) {
    font-size: 1.4rem;
    color: var(--color-text);
    margin-top: 35px;
    margin-bottom: 16px;
    font-weight: 600;
    scroll-margin-top: 100px;
  }

  .markdown-body :global(ul), .markdown-body :global(ol) {
    margin-left: 24px;
    margin-bottom: 24px;
  }

  .markdown-body :global(li) {
    margin-bottom: 10px;
  }

  .markdown-body :global(strong) {
    font-weight: 700;
    color: var(--color-primary-dark);
  }

  .markdown-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 32px auto 12px auto;
    display: block;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--glass-border);
    transition: transform var(--transition-normal);
  }

  .markdown-body :global(img:hover) {
    transform: scale(1.005);
  }

  .markdown-body :global(.image-caption) {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  /* CTA at bottom of post */
  .post-footer-cta {
    background: linear-gradient(135deg, var(--color-primary-glare) 0%, rgba(255, 255, 255, 0.9) 100%);
    padding: 35px;
    border-left: 6px solid var(--color-secondary);
    border-radius: 16px;
    margin-top: 40px;
    margin-bottom: 40px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--glass-border);
    border-left-width: 6px;
  }

  .post-footer-cta h4 {
    font-size: 1.35rem;
    color: var(--color-primary);
    margin-bottom: 14px;
    font-weight: 700;
  }

  .post-footer-cta p {
    font-size: 1rem;
