---
import { getCollection, render } from 'astro:content';

import Layout from '../../layouts/Layout.astro';

// 1. Tạo static paths cho toàn bộ các bài viết
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Lấy dữ liệu bài viết từ props
const { entry } = Astro.props;
const { title, description, pubDate, image, tags } = entry.data;
const { Content } = await render(entry);

const formattedDate = new Date(pubDate).toLocaleDateString('vi-VN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Cấu hình Article Schema động cho SEO Google News/AI search
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": image ? `https://newton.dayboi.vip${image}` : "https://newton.dayboi.vip/images/banner-tuyen-sinh-1.png",
  "datePublished": pubDate.toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "CanSwim Bể bơi Newton"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Trung tâm dạy bơi CanSwim",
    "logo": {
      "@type": "ImageObject",
      "url": "https://newton.dayboi.vip/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://newton.dayboi.vip/cam-nang/${entry.id}`
  }
};

// Lấy danh sách các bài viết mới nhất (tối đa 10 bài, loại trừ bài hiện tại)
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(post => post.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);
---

<Layout 
  title={`${title} | Tin Tức CanSwim`}
  description={description}
  schemaType="Article"
  customSchema={articleSchema}
>
  <article class="blog-post-detail-section">
    <!-- Header -->
    <header class="post-header">
      <div class="container text-center max-width-post-header">
        <a href="/cam-nang" class="back-to-blog">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-back-icon" width="16" height="16"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span>Quay lại Cẩm nang</span>
        </a>
        
        <div class="post-meta">
          <span class="post-date-span">{formattedDate}</span>
          {tags && tags.map(tag => (
            <span class="tag-badge-span">#{tag}</span>
          ))}
        </div>

        <h1 class="post-title-heading">{title}</h1>
        <p class="post-lead-desc">{description}</p>
      </div>
    </header>

    <!-- Cover Image -->
    {image && (
      <div class="container max-width-post-content">
        <div class="post-cover-img-wrapper">
          <img src={image} alt={title} class="post-cover-img" width="1000" height="667" loading="eager" fetchpriority="high" />
        </div>
      </div>
    )}

    <!-- 3-Column Layout -->
    <div class="container max-width-post-layout-3cols">
      <div class="post-layout-grid-3cols">
        <!-- LEFT COLUMN: Table of Contents (20%) -->
        <aside class="post-sidebar-left">
          <div class="sidebar-sticky-wrapper">
            <nav class="toc-box glass-card">
              <h4>MỤC LỤC CHI TIẾT</h4>
              <ul class="toc-list" id="toc-list">
                <!-- Dynamically generated by Scrollspy script -->
              </ul>
            </nav>
          </div>
        </aside>

        <!-- MIDDLE COLUMN: Content (60%) -->
        <div class="post-main-content">
          <div class="markdown-body">
            <Content />
          </div>

          <div class="post-footer-cta glass-card">
            <h4>Đăng Ký Học Bơi Tại Bể Bơi Newton Hôm Nay!</h4>
            <p>Đội ngũ HLV CanSwim chuyên nghiệp trực tiếp kèm sát 1-1 hoặc nhóm nhỏ cam kết chất lượng đầu ra bài bản, đúng kỹ thuật và rèn luyện thể chất toàn diện.</p>
            <div class="post-cta-buttons">
              <a href="/lien-he-chi-duong-be-boi-newton#register" class="btn btn-primary">ĐĂNG KÝ NGAY</a>
              <a href="tel:0907992336" class="btn btn-secondary">HOTLINE: 0907.992.336</a>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Widgets (20%) -->
        <aside class="post-sidebar-right">
          <div class="sidebar-sticky-wrapper">
            <!-- Widget 1: Recent Posts (Max 10) -->
            {recentPosts.length > 0 && (
              <div class="sidebar-box glass-card recent-posts-box">
                <h4>Bài Viết Mới Nhất</h4>
                <ul class="recent-posts-list">
                  {recentPosts.map(post => (
                    <li>
                      <a href={`/cam-nang/${post.id}`}>{post.data.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Widget 2: Course Consultation Form -->
            <div class="sidebar-box glass-card quick-register-box">
              <h4>Tư Vấn Khóa Học</h4>
              <p>Đặt lịch kiểm tra trình độ bơi lội miễn phí cho bé và nhận ưu đãi tốt nhất.</p>
              <a href="/lien-he-chi-duong-be-boi-newton#register" class="btn btn-primary sidebar-btn-register">GỬI THÔNG TIN</a>
            </div>

            <!-- Widget 3: Support Info -->
            <div class="sidebar-box glass-card contact-box-sidebar">
              <h4>Thông Tin Hỗ Trợ</h4>
              <p><strong>Hotline:</strong> 0907.992.336</p>
              <p><strong>Zalo:</strong> <a href="http://zalo.me/0907992336" target="_blank" rel="noopener noreferrer">0907 992 336</a></p>
              <p><strong>Địa chỉ:</strong> Bể bơi Newton, cuối ngõ 234 Hoàng Quốc Việt, Cầu Giấy, HN</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-post-detail-section {
    padding-top: 140px;
    padding-bottom: 80px;
    background-color: var(--color-bg);
  }

  .post-header {
    margin-bottom: 50px;
    position: relative;
  }
  
  /* Soft background glow for the article header */
  .post-header::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 102, 170, 0.06) 0%, rgba(255, 255, 255, 0) 70%);
    z-index: 1;
    pointer-events: none;
  }

  .max-width-post-header {
    max-width: 950px;
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 24px;
    position: relative;
    z-index: 2;
    transition: transform var(--transition-fast);
  }

  .back-to-blog:hover {
    color: var(--color-primary-light);
    transform: translateX(-4px);
  }

  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }

  .post-date-span {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .post-date-span::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-secondary);
  }

  .tag-badge-span {
    background-color: var(--color-primary-glare);
    color: var(--color-primary);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    transition: all var(--transition-fast);
  }

  .tag-badge-span:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .post-title-heading {
    font-size: 3.2rem;
    line-height: 1.25;
    font-weight: 800;
    color: var(--color-primary);
    margin-top: 15px;
    margin-bottom: 24px;
    letter-spacing: -0.8px;
    font-family: var(--font-heading);
    position: relative;
    z-index: 2;
    background: linear-gradient(135deg, var(--color-primary-dark) 30%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-lead-desc {
    font-size: 1.25rem;
    color: var(--color-text);
    line-height: 1.8;
    max-width: 850px;
    margin: 30px auto 0 auto;
    padding: 24px 30px;
    border-left: 6px solid var(--color-secondary);
    background: linear-gradient(135deg, var(--color-primary-glare) 0%, rgba(255, 255, 255, 0.8) 100%);
    backdrop-filter: blur(8px);
    border-radius: 4px 20px 20px 4px;
    text-align: left;
    box-shadow: 0 8px 30px rgba(0, 50, 100, 0.04);
    position: relative;
    z-index: 2;
    font-style: italic;
  }

  /* Cover image displaying 100% full content */
  .max-width-post-content {
    max-width: 1200px;
    margin-bottom: 60px;
    position: relative;
    z-index: 2;
  }

  .post-cover-img-wrapper {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--glass-border);
    width: 100%;
    height: auto;
    background-color: var(--color-white);
    transition: transform var(--transition-slow);
  }

  .post-cover-img-wrapper:hover {
    transform: scale(1.005);
  }

  .post-cover-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* 3-Column layout configuration */
  .max-width-post-layout-3cols {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding-left: 30px;
    padding-right: 30px;
  }

  .post-layout-grid-3cols {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 6fr) minmax(0, 2fr);
    gap: 40px;
    align-items: flex-start;
  }

  /* Left sidebar - TOC (20%) */
  .post-sidebar-left {
    position: sticky;
    top: 100px;
    align-self: start;
    height: auto;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: none; /* Hide scrollbar for clean look */
    padding-bottom: 20px;
  }

  .post-sidebar-left::-webkit-scrollbar {
    display: none;
  }

  /* Right sidebar - Widgets (20%) */
  .post-sidebar-right {
    position: sticky;
    top: 100px;
    align-self: start;
    height: auto;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    scrollbar-width: none;
    padding-bottom: 20px;
  }

  .post-sidebar-right::-webkit-scrollbar {
    display: none;
  }

  .sidebar-sticky-wrapper {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* TOC styling */
  .toc-box {
    padding: 24px;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
  }

  .toc-box h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 20px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 10px;
  }

  .toc-list {
    list-style: none;
    padding-left: 16px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-left: 1px solid rgba(0, 102, 170, 0.1);
    position: relative;
  }

  .toc-item {
    position: relative;
  }

  .toc-item a {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.4;
    transition: all var(--transition-fast);
    display: block;
    text-decoration: none;
  }

  .toc-item.h2-item {
    font-weight: 600;
  }

  .toc-item.h3-item {
    padding-left: 12px;
  }

  .toc-item:hover a {
    color: var(--color-primary);
  }

  .toc-item.active a {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* Active marker at the track line */
  .toc-item.active::before {
    content: '';
    position: absolute;
    left: -18px; /* aligns exactly with the border-left line of .toc-list */
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 16px;
    background-color: var(--color-secondary);
    border-radius: 2px;
  }

  /* Recent Posts Widget */
  .recent-posts-box {
    padding: 24px;
    border-radius: 20px;
  }

  .recent-posts-box h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 20px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 10px;
  }

  .recent-posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .recent-posts-list li {
    border-bottom: 1px dashed var(--glass-border);
    padding-bottom: 10px;
  }

  .recent-posts-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .recent-posts-list li a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    transition: color var(--transition-fast);
    line-height: 1.4;
    display: block;
    text-decoration: none;
  }

  .recent-posts-list li a:hover {
    color: var(--color-primary);
  }

  /* Markdown body render */
  .markdown-body {
    line-height: 1.9;
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 50px;
  }

  .markdown-body :global(p) {
    margin-bottom: 24px;
  }

  .markdown-body :global(h2) {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-top: 45px;
    margin-bottom: 20px;
    font-weight: 700;
    scroll-margin-top: 100px; /* Offset for sticky header when jumping from TOC */
    border-bottom: 1px solid var(--color-primary-glare);
    padding-bottom: 8px;
  }

  .markdown-body :global(h3) {
    font-size: 1.4rem;
    color: var(--color-text);
    margin-top: 35px;
    margin-bottom: 16px;
    font-weight: 600;
    scroll-margin-top: 100px;
  }

  .markdown-body :global(ul), .markdown-body :global(ol) {
    margin-left: 24px;
    margin-bottom: 24px;
  }

  .markdown-body :global(li) {
    margin-bottom: 10px;
  }

  .markdown-body :global(strong) {
    font-weight: 700;
    color: var(--color-primary-dark);
  }

  .markdown-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 32px auto 12px auto;
    display: block;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--glass-border);
    transition: transform var(--transition-normal);
  }

  .markdown-body :global(img:hover) {
    transform: scale(1.005);
  }

  .markdown-body :global(.image-caption) {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  /* CTA at bottom of post */
  .post-footer-cta {
    background: linear-gradient(135deg, var(--color-primary-glare) 0%, rgba(255, 255, 255, 0.9) 100%);
    padding: 35px;
    border-left: 6px solid var(--color-secondary);
    border-radius: 16px;
    margin-top: 40px;
    margin-bottom: 40px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--glass-border);
    border-left-width: 6px;
  }

  .post-footer-cta h4 {
    font-size: 1.35rem;
    color: var(--color-primary);
    margin-bottom: 14px;
    font-weight: 700;
  }

  .post-footer-cta p {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .post-cta-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .post-cta-buttons a {
    padding: 12px 24px;
    font-size: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
  }

  /* Sidebar widgets general */
  .sidebar-box {
    padding: 24px;
    border-radius: 20px;
  }

  .sidebar-box h4 {
    font-size: 0.95rem;
    color: var(--color-primary);
    margin-bottom: 12px;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 8px;
    font-weight: 700;
  }

  .sidebar-box p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  /* Course Consultation Box */
  .quick-register-box {
    background: linear-gradient(135deg, var(--color-primary-glare) 0%, var(--color-white) 100%);
    border-left: 4px solid var(--color-secondary);
  }

  .sidebar-btn-register {
    width: 100%;
    padding: 12px;
    font-size: 0.85rem;
    border-radius: 8px;
    text-decoration: none;
    display: block;
    text-align: center;
    background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-light) 100%);
    color: var(--color-white);
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(255, 122, 0, 0.2);
    border: none;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .sidebar-btn-register:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(255, 122, 0, 0.35);
  }

  /* Support Info Box */
  .contact-box-sidebar {
    background: var(--glass-bg);
  }

  .contact-box-sidebar p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .contact-box-sidebar p strong {
    color: var(--color-text);
  }
  
  .contact-box-sidebar a {
    color: var(--color-primary);
    font-weight: 600;
    border-bottom: 1px dashed var(--color-primary);
  }
  
  .contact-box-sidebar a:hover {
    color: var(--color-primary-light);
    border-bottom-color: var(--color-primary-light);
  }

  /* Responsive breakpoints */
  @media (max-width: 1200px) {
    .post-layout-grid-3cols {
      grid-template-columns: minmax(0, 2.2fr) minmax(0, 5.6fr) minmax(0, 2.2fr);
      gap: 24px;
    }
  }

  @media (max-width: 1024px) {
    .post-title-heading {
      font-size: 2.5rem;
    }

    .post-layout-grid-3cols {
      grid-template-columns: minmax(0, 7fr) minmax(0, 3fr);
      gap: 30px;
    }

    .post-sidebar-left {
      display: none; /* Hide TOC on tablet */
    }

    .post-sidebar-right {
      position: sticky;
      top: 100px;
    }
  }

  @media (max-width: 768px) {
    .post-title-heading {
      font-size: 2rem;
    }

    .post-lead-desc {
      font-size: 1.15rem;
      padding: 20px;
    }

    .post-layout-grid-3cols {
      grid-template-columns: minmax(0, 1fr);
      gap: 30px;
    }

    .post-sidebar-right {
      position: static;
      max-height: none;
      overflow-y: visible;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Tự động tạo danh sách mục lục (TOC)
    const headings = document.querySelectorAll('.markdown-body h2, .markdown-body h3');
    const tocList = document.getElementById('toc-list');
    
    if (!tocList) return;
    
    if (headings.length === 0) {
      tocList.innerHTML = '<li class="toc-item"><span class="no-toc-data" style="font-size: 0.82rem; color: var(--color-text-muted); font-style: italic;">Không có đề mục lớn</span></li>';
      return;
    }

    headings.forEach((heading, index) => {
      // Đặt ID cho thẻ nếu chưa có
      if (!heading.id) {
        const rawText = heading.textContent || '';
        const safeId = 'muc-' + rawText.toLowerCase()
          .replace(/[áàảãạăắằẳẵặâấầẩẫậ]/g, 'a')
          .replace(/[éèẻẽẹêếềểễệ]/g, 'e')
          .replace(/[íìỉĩị]/g, 'i')
          .replace(/[óòỏõọôốồổỗộơớờởỡợ]/g, 'o')
          .replace(/[úùủũụưứừửữự]/g, 'u')
          .replace(/[ýỳỷỹỵ]/g, 'y')
          .replace(/đ/g, 'd')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '') || 'de-muc-' + index;
          
        heading.id = safeId;
      }

      // Tạo thẻ li và a tương ứng
      const li = document.createElement('li');
      li.className = heading.tagName.toLowerCase() === 'h2' ? 'toc-item h2-item' : 'toc-item h3-item';
      
      const a = document.createElement('a');
      a.href = '#' + heading.id;
      a.textContent = heading.textContent;
      
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // 2. Scrollspy - Highlight mục lục tương ứng khi cuộn trang
    const observerOptions = {
      root: null,
      rootMargin: '-100px 0px -75%',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          document.querySelectorAll('.toc-item').forEach(item => {
            const link = item.querySelector('a');
            if (link && link.getAttribute('href') === '#' + id) {
              item.classList.add('active');
            } else {
              item.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach(heading => observer.observe(heading));
  });
</script>
