<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-tab-btn, .tag-cloud-btn');
    const searchInput = document.getElementById('blog-search');
    const blogCards = document.querySelectorAll('.grid-blog-card');
    const noResultsBox = document.getElementById('no-results-message');
    const heroSection = document.getElementById('featured-hero-article');
    
    let activeCategory = 'all';
    let searchQuery = '';
    
    function filterPosts() {
      let visibleCount = 0;
      
      // Cập nhật trạng thái active cho các nút danh mục trên thanh công cụ
      document.querySelectorAll('.filter-tab-btn').forEach(btn => {
        if (btn.getAttribute('data-filter') === activeCategory) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      
      const isViewingAllNoSearch = activeCategory === 'all' && searchQuery === '';
      
      // Ẩn/Hiện bài viết tiêu điểm Hero ở trên đầu
      if (heroSection) {
        heroSection.style.display = isViewingAllNoSearch ? 'block' : 'none';
      }
      
      // Duyệt qua từng bài viết trong grid để lọc
      blogCards.forEach(card => {
        const categories = card.getAttribute('data-categories').split(',');
        const title = card.getAttribute('data-title').toLowerCase();
        const desc = card.getAttribute('data-desc').toLowerCase();
        
        const matchesCategory = activeCategory === 'all' || categories.includes(activeCategory);
        const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);
        
        const isDuplicate = card.classList.contains('is-featured-post-duplicate');
        
        if (matchesCategory && matchesSearch) {
          // Nếu bài viết này trùng với bài viết tiêu điểm Hero ở trên, 
          // và người dùng đang ở chế độ xem 'Tất cả' + không tìm kiếm, hãy ẩn nó trong grid để tránh bị lặp
          if (isDuplicate && isViewingAllNoSearch) {
            card.style.display = 'none';
          } else {
            card.style.display = 'flex';
            visibleCount++;
          }
        } else {
          card.style.display = 'none';
        }
      });
      
      // Ẩn/Hiện thông báo không tìm thấy kết quả
      if (visibleCount === 0) {
        noResultsBox.style.display = 'block';
      } else {
        noResultsBox.style.display = 'none';
      }
    }
    
    // Gán sự kiện click cho các nút danh mục và tag cloud bên sidebar
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.getAttribute('data-filter');
        filterPosts();
        
        // Cuộn mượt mà về vùng danh sách bài viết trên màn hình nhỏ để tăng trải nghiệm người dùng
        if (window.innerWidth <= 1024) {
          const toolbar = document.querySelector('.portal-toolbar');
          if (toolbar) {
            toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
    
    // Gán sự kiện tìm kiếm thời gian thực
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        filterPosts();
      });
    }
    
    // Khởi chạy bộ lọc ban đầu để ẩn bản sao bài viết tiêu điểm
    filterPosts();
  });
</script>
