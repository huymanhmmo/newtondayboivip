---
import { getCollection } from 'astro:content';

import Layout from '../../layouts/Layout.astro';

// Fetch bài viết và sắp xếp theo ngày xuất bản giảm dần (mới nhất lên đầu)
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
  title="Cẩm Nang Học Bơi & Tin Tức Bể Bơi Newton Cầu Giấy"
  description="Chia sẻ kinh nghiệm dạy học bơi trẻ em, người lớn, review cơ sở vật chất bể bơi Newton 234 Hoàng Quốc Việt và hướng dẫn kỹ năng phòng chống đuối nước."
  schemaType="WebSite"
>
  <!-- Page Header -->
  <section class="page-header-section blog-theme">
    <div class="container text-center">
      <span class="page-meta-badge">Cẩm nang bơi lội</span>
      <h1 class="page-title-main">TIN TỨC & KINH NGHIỆM HỌC BƠI</h1>
      <p class="page-desc-main">Khám phá các bài viết tư vấn hữu ích từ các chuyên gia CanSwim về phương pháp dạy học bơi cho bé, review bể bơi Cầu Giấy và kỹ năng sinh tồn nước.</p>
    </div>
  </section>

  <!-- Blog Listing -->
  <section class="section-padding blog-list-section">
    <div class="container">
      {sortedPosts.length === 0 ? (
        <div class="no-posts-box text-center glass-card">
          <p>Hiện tại chưa có bài viết nào được xuất bản. Vui lòng quay lại sau.</p>
        </div>
      ) : (
        <div class="blog-posts-grid">
          {sortedPosts.map((post) => {
            const formattedDate = new Date(post.data.pubDate).toLocaleDateString('vi-VN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            });

            return (
              <article class="blog-card glass-card">
                {post.data.image && (
                  <div class="blog-card-img-wrapper">
                    <a href={`/cam-nang/${post.id}`}>
                      <img src={post.data.image} alt={post.data.title} class="blog-card-img" width="540" height="360" loading="lazy" />
                    </a>
                  </div>
                )}
                
                <div class="blog-card-content">
                  <div class="blog-card-meta">
                    <span class="blog-date">{formattedDate}</span>
                    {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
                      <span class="blog-tag-badge">#{tag}</span>
                    ))}
                  </div>

                  <h3 class="blog-card-title">
                    <a href={`/cam-nang/${post.id}`}>{post.data.title}</a>
                  </h3>

                  <p class="blog-card-desc">{post.data.description}</p>

                  <a href={`/cam-nang/${post.id}`} class="btn btn-secondary btn-read-more">ĐỌC CHI TIẾT</a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- Expanded Content for SEO Depth -->
  <section class="section-padding blog-expanded-seo-section">
    <div class="container expanded-content-box">
      <h2 class="expanded-title">Học Hỏi Kinh Nghiệm Bơi Lội Cùng HLV Bùi Văn Cán</h2>
      <p class="intro-p">Cẩm nang bơi lội CanSwim là nơi hội tụ các bài viết chia sẻ chuyên sâu về kỹ thuật bơi lội, phương pháp sư phạm dạy bơi cho trẻ nhỏ, khóa học bơi người lớn và các cập nhật mới nhất về địa điểm học bơi tại quận Cầu Giấy.</p>
      
      <div class="seo-text-grid">
        <div class="seo-col-box">
          <h3 class="seo-sub-title">Mục tiêu chia sẻ kiến thức của CanSwim</h3>
          <p class="intro-p">Chúng tôi mong muốn mang lại những thông tin hữu ích nhất để bảo vệ an toàn cho mọi người dưới nước. Dưới sự chỉ đạo của HLV trưởng Bùi Văn Cán, các bài viết được đầu tư nghiêm túc về mặt chuyên môn sư phạm bơi lội.</p>
          
          <h4 class="seo-leaf-title">Phổ cập kiến thức bơi lội an toàn nước</h4>
          <p class="intro-p">Cung cấp các kỹ năng phòng chống đuối nước tự cứu, cách xử lý sự cố chuột rút hoặc kiệt sức khi bơi ở sông hồ hay bể nước sâu.</p>
          
          <h4 class="seo-leaf-title">Rèn luyện kỹ thuật bơi đúng chuẩn sư phạm</h4>
          <p class="intro-p">Hướng dẫn chi tiết cơ chế vật lý của lực nổi dưới nước, giúp học viên hiểu rõ cách thả lỏng tự nhiên để thực hành tốt kỹ thuật bơi sải, bơi ếch, bơi ngửa.</p>
        </div>

        <div class="seo-col-box">
          <h3 class="seo-sub-title">Các khóa học bơi tiêu chuẩn tại bể bơi Newton</h3>
          <p class="intro-p">Học viên quan tâm đến các khóa đào tạo bài bản có thể tìm hiểu thêm các thông tin hữu ích về dịch vụ giảng dạy kèm riêng chất lượng cao của trung tâm:</p>
          
          <h4 class="seo-leaf-title">Khóa học bơi trẻ em và người lớn</h4>
          <p class="intro-p">Đăng ký lớp học bơi tại trung tâm với các ca học vô cùng linh động. Tìm hiểu thêm thông tin chi tiết tại trang <a href="/lop-hoc-boi-tre-em-be-boi-newton/">Lớp học bơi trẻ em bể bơi Newton</a> và trang <a href="/hoc-boi-nguoi-lon-be-boi-newton/">Lớp học bơi người lớn bể bơi Newton</a> của chúng tôi.</p>
          
          <h4 class="seo-leaf-title">Lịch học và học phí ưu đãi mới nhất</h4>
          <p class="intro-p">Bảng giá trọn gói và các chương trình khuyến mại tặng vé bơi được cập nhật công khai tại trang <a href="/lich-hoc-hoc-phi-day-boi-newton/">Lịch học và học phí dạy bơi Newton</a>.</p>
        </div>
      </div>

      <div class="seo-footer-box">
        <h3 class="seo-sub-title">Địa điểm học và liên hệ tư vấn trực tiếp</h3>
        <p class="intro-p">Lớp học bơi của trung tâm được tổ chức tại <a href="/be-boi-newton-hoang-quoc-viet/">bể bơi Newton Cầu Giấy</a>. Để nhận được tư vấn chi tiết từ huấn luyện viên và giữ chỗ khóa học gần nhất, kính mời quý phụ huynh xem chỉ đường và điền biểu mẫu liên hệ tại trang <a href="/lien-he/">Liên hệ và chỉ đường bể bơi Newton</a>. Quý học viên cũng có thể theo dõi và tương tác trực tuyến cùng chúng tôi qua <a href="https://www.facebook.com/beboinewton" target="_blank" rel="noopener noreferrer">Fanpage Facebook Bể bơi Newton</a>.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Grid layout */
  .blog-list-section {
    background-color: var(--color-bg);
  }

  .blog-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  @media (max-width: 1024px) {
    .blog-posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .blog-posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 102, 170, 0.12);
    border-color: var(--color-primary-light);
  }

  .blog-card-img-wrapper {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .blog-card-img {
    transform: scale(1.05);
  }

  .blog-card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .blog-date {
    color: var(--color-text-muted);
  }

  .blog-tag-badge {
    color: var(--color-primary);
    background-color: var(--color-primary-glare);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .blog-card-title {
    font-size: 1.2rem;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.4;
    white-space: normal !important;
  }

  .blog-card-title a:hover {
    color: var(--color-primary);
  }

  .blog-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .btn-read-more {
    width: 100%;
    padding: 10px;
    font-size: 0.85rem;
    border-radius: 8px;
  }

  .no-posts-box {
    padding: 50px 20px;
    color: var(--color-text-muted);
  }

  /* Expanded SEO Content styling */
  .blog-expanded-seo-section {
    background-color: var(--color-bg-alt);
    border-top: 1px solid rgba(0, 102, 170, 0.05);
  }

  .expanded-content-box {
    max-width: 1000px;
    margin: 0 auto;
  }

  .expanded-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 20px;
    text-align: center;
  }

  .seo-text-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 30px;
  }

  .seo-sub-title {
    font-size: 1.3rem;
    color: var(--color-text);
    margin-bottom: 15px;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 6px;
  }

  .seo-leaf-title {
    font-size: 1.05rem;
    color: var(--color-primary-dark);
    margin: 15px 0 5px 0;
  }

  .seo-footer-box {
    margin-top: 30px;
    background-color: var(--color-white);
    padding: 30px;
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
  }

  .intro-p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 15px;
  }

  @media (max-width: 768px) {
    .seo-text-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
