---
import { getCollection } from 'astro:content';

import Layout from '../../layouts/Layout.astro';

// Fetch bài viết và sắp xếp theo ngày xuất bản giảm dần (mới nhất lên đầu)
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = sortedPosts[0];
const gridPosts = sortedPosts;

// Phân loại danh mục cho từng bài viết để phục vụ bộ lọc thời gian thực
const getCategories = (tags: string[]): string[] => {
  const categories = ['all'];
  const ts = (tags || []).map(t => t.toLowerCase());
  
  if (ts.some(t => t.includes('trẻ em') || t.includes('bé') || t.includes('học sinh') || t.includes('tiểu học') || t.includes('dạy bơi trẻ em'))) {
    categories.push('tre-em');
  }
  if (ts.some(t => t.includes('người lớn'))) {
    categories.push('nguoi-lon');
  }
  if (ts.some(t => t.includes('kỹ thuật') || t.includes('giáo trình') || t.includes('tự học') || t.includes('sải') || t.includes('ếch') || t.includes('phối hợp') || t.includes('cách tự học'))) {
    categories.push('ky-thuat');
  }
  if (ts.some(t => t.includes('học phí') || t.includes('giá rẻ') || t.includes('giá 1 khóa') || t.includes('lớp bơi tập thể'))) {
    categories.push('hoc-phi');
  }
  if (ts.some(t => t.includes('đường đi') || t.includes('bản đồ') || t.includes('chỉ đường') || t.includes('review') || t.includes('ở đâu') || t.includes('gửi xe') || t.includes('so sánh'))) {
    categories.push('review');
  }
  
  if (categories.length === 1) {
    categories.push('tin-tuc');
  }
  
  return categories;
}
---

<Layout 
  title="Cẩm Nang Học Bơi & Tin Tức Bể Bơi Newton Cầu Giấy"
  description="Chia sẻ kinh nghiệm dạy học bơi trẻ em, người lớn, review cơ sở vật chất bể bơi Newton 234 Hoàng Quốc Việt và hướng dẫn kỹ năng phòng chống đuối nước."
  schemaType="WebSite"
>
  <!-- Page Header -->
  <section class="page-header-section blog-theme">
    <div class="container text-center">
      <span class="page-meta-badge">Cẩm nang bơi lội</span>
      <h1 class="page-title-main">TIN TỨC & KINH NGHIỆM HỌC BƠI</h1>
      <p class="page-desc-main">Khám phá các bài viết tư vấn hữu ích từ các chuyên gia CanSwim về phương pháp dạy học bơi cho bé, review bể bơi Cầu Giấy và kỹ năng sinh tồn nước.</p>
    </div>
  </section>

  <!-- Featured Post Hero Section -->
  {featuredPost && (
    <section class="section-padding featured-hero-section" id="featured-hero-article">
      <div class="container">
        <div class="featured-hero-card glass-card">
          <div class="hero-card-grid">
            {featuredPost.data.image && (
              <div class="hero-image-wrapper">
                <a href={`/cam-nang/${featuredPost.id}`}>
                  <img src={featuredPost.data.image} alt={featuredPost.data.title} class="hero-image" width="750" height="500" loading="eager" />
                </a>
                <span class="hero-badge">🔥 Mới Nhất</span>
              </div>
            )}
            <div class="hero-content-wrapper">
              <div class="hero-meta">
                <span class="hero-date">{new Date(featuredPost.data.pubDate).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                {featuredPost.data.tags && featuredPost.data.tags.slice(0, 2).map(tag => (
                  <span class="hero-tag-badge">#{tag}</span>
                ))}
              </div>
              <h2 class="hero-title">
                <a href={`/cam-nang/${featuredPost.id}`}>{featuredPost.data.title}</a>
              </h2>
              <p class="hero-desc">{featuredPost.data.description}</p>
              
              <div class="hero-author-footer">
                <div class="hero-author-info">
                  <img src="/images/thay-bui-van-can-canswim.jpg" alt="HLV Bùi Văn Cán" class="hero-author-avatar" />
                  <div>
                    <span class="hero-author-name">HLV Bùi Văn Cán</span>
                    <span class="hero-author-title">HLV Trưởng CanSwim</span>
                  </div>
                </div>
                <a href={`/cam-nang/${featuredPost.id}`} class="btn btn-primary hero-read-btn">ĐỌC BÀI VIẾT</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Blog Listing & Sidebar Portal -->
  <section class="section-padding blog-portal-section">
    <div class="container">
      
      <!-- Interactive Filter & Search Bar Row -->
      <div class="portal-toolbar glass-card">
        <div class="filter-tabs-wrapper">
          <button class="filter-tab-btn active" data-filter="all">Tất cả</button>
          <button class="filter-tab-btn" data-filter="tre-em">Trẻ em</button>
          <button class="filter-tab-btn" data-filter="nguoi-lon">Người lớn</button>
          <button class="filter-tab-btn" data-filter="ky-thuat">Kỹ thuật bơi</button>
          <button class="filter-tab-btn" data-filter="hoc-phi">Học phí & Gói lớp</button>
          <button class="filter-tab-btn" data-filter="review">Review & Đường đi</button>
        </div>
        
        <div class="search-box-wrapper">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input type="text" id="blog-search" placeholder="Tìm kiếm bài viết..." class="search-input" />
        </div>
      </div>

      <div class="portal-layout-grid">
        <!-- Left Column: Blog Cards Grid (72%) -->
        <main class="portal-main-content">
          {sortedPosts.length === 0 ? (
            <div class="no-posts-box text-center glass-card">
              <p>Hiện tại chưa có bài viết nào được xuất bản. Vui lòng quay lại sau.</p>
            </div>
          ) : (
            <div class="blog-posts-grid-portal" id="blog-posts-container">
              {gridPosts.map((post, index) => {
                const formattedDate = new Date(post.data.pubDate).toLocaleDateString('vi-VN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                });
                
                const categories = getCategories(post.data.tags);
                const categoriesStr = categories.join(',');
                const isDuplicate = index === 0;

                return (
                  <article 
                    class={`grid-blog-card glass-card ${isDuplicate ? 'is-featured-post-duplicate' : ''}`}
                    data-categories={categoriesStr}
                    data-title={post.data.title}
                    data-desc={post.data.description}
                  >
                    {post.data.image && (
                      <div class="blog-card-img-wrapper">
                        <a href={`/cam-nang/${post.id}`}>
                          <img src={post.data.image} alt={post.data.title} class="blog-card-img" width="540" height="360" loading="lazy" />
                        </a>
                      </div>
                    )}
                    
                    <div class="blog-card-content">
                      <div class="blog-card-meta">
                        <span class="blog-date">{formattedDate}</span>
                        {post.data.tags && post.data.tags.slice(0, 1).map(tag => (
                          <span class="blog-tag-badge">#{tag}</span>
                        ))}
                      </div>

                      <h3 class="blog-card-title">
                        <a href={`/cam-nang/${post.id}`}>{post.data.title}</a>
                      </h3>

                      <p class="blog-card-desc">{post.data.description}</p>

                      <a href={`/cam-nang/${post.id}`} class="btn btn-secondary btn-read-more">ĐỌC CHI TIẾT</a>
                    </div>
                  </article>
                );
              })}
            </div>
          )}
          
          <!-- No Results Message (Hidden by default) -->
          <div id="no-results-message" class="no-posts-box text-center glass-card" style="display: none;">
            <p>Không tìm thấy bài viết nào phù hợp với bộ lọc hoặc từ khóa tìm kiếm của bạn.</p>
          </div>
        </main>
        
        <!-- Right Column: Sidebar Widgets (28%) -->
        <aside class="portal-sidebar">
          
          <!-- Widget 1: Author Card -->
          <div class="sidebar-widget glass-card author-widget">
            <h4 class="widget-title">Ban Biên Tập</h4>
            <div class="author-widget-body">
              <img src="/images/thay-bui-van-can-canswim.jpg" alt="HLV Bùi Văn Cán" class="author-widget-avatar" />
              <h5 class="author-widget-name">HLV Bùi Văn Cán</h5>
              <span class="author-widget-title">Cố vấn chuyên môn sư phạm</span>
              <p class="author-widget-bio">Cựu vận động viên cấp cao, hơn 10 năm kinh nghiệm trực tiếp kèm học viên bơi lội và xây dựng giáo trình giảng dạy tại CanSwim Bể bơi Newton.</p>
              <div class="author-widget-social">
                <a href="https://www.facebook.com/beboinewton" target="_blank" rel="noopener noreferrer" aria-label="Facebook Bể bơi Newton">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                  <span>Theo dõi Fanpage</span>
                </a>
              </div>
            </div>
          </div>
          
          <!-- Widget 2: Popular Tags -->
          <div class="sidebar-widget glass-card tags-widget">
            <h4 class="widget-title">Chủ Đề Phổ Biến</h4>
            <div class="tags-cloud">
              <button class="tag-cloud-btn" data-filter="tre-em"># Dạy bơi trẻ em</button>
              <button class="tag-cloud-btn" data-filter="nguoi-lon"># Bơi người lớn</button>
              <button class="tag-cloud-btn" data-filter="ky-thuat"># Kỹ thuật bơi lội</button>
              <button class="tag-cloud-btn" data-filter="hoc-phi"># Học phí & Gói lớp</button>
              <button class="tag-cloud-btn" data-filter="review"># Review & Đường đi</button>
            </div>
          </div>
          
          <!-- Widget 3: Hotline Callout Banner -->
          <div class="sidebar-widget cta-widget">
            <div class="cta-widget-glow"></div>
            <div class="cta-widget-content">
              <span class="cta-subtitle">KHÓA HỌC CHỦ LỰC</span>
              <h4 class="cta-title">Học Bơi Kèm Riêng Bể Bơi Newton</h4>
              <p class="cta-text">Tặng 15 buổi tự bơi khi đăng ký khóa 15 buổi cùng HLV. Tổng cộng 30 lượt vào bể bơi mát mẻ, có mái che!</p>
              <div class="cta-hotline">Hotline: 0907.992.336</div>
              <a href="/lien-he#register" class="btn btn-primary cta-btn">ĐĂNG KÝ GIỮ CHỖ</a>
            </div>
          </div>
          
        </aside>
      </div>
    </div>
  </section>

  <!-- Expanded Content for SEO Depth -->
  <section class="section-padding blog-expanded-seo-section">
    <div class="container expanded-content-box">
      <h2 class="expanded-title">Học Hỏi Kinh Nghiệm Bơi Lội Cùng HLV Bùi Văn Cán</h2>
      <p class="intro-p">Cẩm nang bơi lội CanSwim là nơi hội tụ các bài viết chia sẻ chuyên sâu về kỹ thuật bơi lội, phương pháp sư phạm dạy bơi cho trẻ nhỏ, khóa học bơi người lớn và các cập nhật mới nhất về địa điểm học bơi tại quận Cầu Giấy.</p>
      
      <div class="seo-text-grid">
        <div class="seo-col-box">
          <h3 class="seo-sub-title">Mục tiêu chia sẻ kiến thức của CanSwim</h3>
          <p class="intro-p">Chúng tôi mong muốn mang lại những thông tin hữu ích nhất để bảo vệ an toàn cho mọi người dưới nước. Dưới sự chỉ đạo của HLV trưởng Bùi Văn Cán, các bài viết được đầu tư nghiêm túc về mặt chuyên môn sư phạm bơi lội.</p>
          
          <h4 class="seo-leaf-title">Phổ cập kiến thức bơi lội an toàn nước</h4>
          <p class="intro-p">Cung cấp các kỹ năng phòng chống đuối nước tự cứu, cách xử lý sự cố chuột rút hoặc kiệt sức khi bơi ở sông hồ hay bể nước sâu.</p>
          
          <h4 class="seo-leaf-title">Rèn luyện kỹ thuật bơi đúng chuẩn sư phạm</h4>
          <p class="intro-p">Hướng dẫn chi tiết cơ chế vật lý của lực nổi dưới nước, giúp học viên hiểu rõ cách thả lỏng tự nhiên để thực hành tốt kỹ thuật bơi sải, bơi ếch, bơi ngửa.</p>
        </div>

        <div class="seo-col-box">
          <h3 class="seo-sub-title">Các khóa học bơi tiêu chuẩn tại bể bơi Newton</h3>
          <p class="intro-p">Học viên quan tâm đến các khóa đào tạo bài bản có thể tìm hiểu thêm các thông tin hữu ích về dịch vụ giảng dạy kèm riêng chất lượng cao của trung tâm:</p>
          
          <h4 class="seo-leaf-title">Khóa học bơi trẻ em và người lớn</h4>
          <p class="intro-p">Đăng ký lớp học bơi tại trung tâm với các ca học vô cùng linh động. Tìm hiểu thêm thông tin chi tiết tại trang <a href="/lop-hoc-boi-tre-em-be-boi-newton/">Lớp học bơi trẻ em bể bơi Newton</a> và trang <a href="/hoc-boi-nguoi-lon-be-boi-newton/">Lớp học bơi người lớn bể bơi Newton</a> của chúng tôi.</p>
          
          <h4 class="seo-leaf-title">Lịch học và học phí ưu đãi mới nhất</h4>
          <p class="intro-p">Bảng giá trọn gói và các chương trình khuyến mại tặng vé bơi được cập nhật công khai tại trang <a href="/lich-hoc-hoc-phi-day-boi-newton/">Lịch học và học phí dạy bơi Newton</a>.</p>
        </div>
      </div>

      <div class="seo-footer-box">
        <h3 class="seo-sub-title">Địa điểm học và liên hệ tư vấn trực tiếp</h3>
        <p class="intro-p">Lớp học bơi của trung tâm được tổ chức tại <a href="/be-boi-newton-hoang-quoc-viet/">bể bơi Newton Cầu Giấy</a>. Để nhận được tư vấn chi tiết từ huấn luyện viên và giữ chỗ khóa học gần nhất, kính mời quý phụ huynh xem chỉ đường và điền biểu mẫu liên hệ tại trang <a href="/lien-he/">Liên hệ và chỉ đường bể bơi Newton</a>. Quý học viên cũng có thể theo dõi và tương tác trực tuyến cùng chúng tôi qua <a href="https://www.facebook.com/beboinewton" target="_blank" rel="noopener noreferrer">Fanpage Facebook Bể bơi Newton</a>.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Portal Grid Layout */
  .blog-portal-section {
    background-color: var(--color-bg);
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .portal-layout-grid {
    display: grid;
    grid-template-columns: minmax(0, 7.2fr) minmax(0, 2.8fr);
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .portal-layout-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 50px;
    }
  }

  /* Portal Toolbar (Filter Tabs + Search) */
  .portal-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 16px 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
  }

  .filter-tabs-wrapper {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-tab-btn {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    padding: 8px 18px;
    border-radius: 99px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: var(--font-heading);
  }

  .filter-tab-btn:hover {
    background-color: rgba(0, 102, 170, 0.05);
    color: var(--color-primary);
    border-color: var(--color-primary-light);
  }

  .filter-tab-btn.active {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: var(--color-white);
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(0, 102, 170, 0.2);
  }

  .search-box-wrapper {
    position: relative;
    width: 280px;
  }

  @media (max-width: 850px) {
    .portal-toolbar {
      flex-direction: column;
      align-items: stretch;
    }
    .search-box-wrapper {
      width: 100%;
    }
  }

  .search-input {
    width: 100%;
    padding: 10px 16px 10px 42px;
    border-radius: 99px;
    border: 1px solid var(--glass-border);
    background-color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    transition: all var(--transition-fast);
    color: var(--color-text);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background-color: var(--color-white);
    box-shadow: 0 0 0 3px rgba(0, 102, 170, 0.15);
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  /* Main Area Grid */
  .blog-posts-grid-portal {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 30px;
  }

  @media (max-width: 600px) {
    .blog-posts-grid-portal {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  /* Portal Grid Card */
  .grid-blog-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .grid-blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 102, 170, 0.12);
    border-color: var(--color-primary-light);
  }

  .blog-card-img-wrapper {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    position: relative;
    border-bottom: 1px solid var(--glass-border);
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .grid-blog-card:hover .blog-card-img {
    transform: scale(1.05);
  }

  .blog-card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .blog-date {
    color: var(--color-text-muted);
  }

  .blog-tag-badge {
    color: var(--color-primary);
    background-color: var(--color-primary-glare);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .blog-card-title {
    font-size: 1.15rem;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.4;
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .blog-card-title a {
    transition: color var(--transition-fast);
  }

  .blog-card-title a:hover {
    color: var(--color-primary);
  }

  .blog-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 20px;
    flex-grow: 1;
    text-align: justify;
  }

  .btn-read-more {
    width: 100%;
    padding: 10px;
    font-size: 0.85rem;
    border-radius: 8px;
  }

  /* Featured Hero Card Style */
  .featured-hero-section {
    background-color: var(--color-bg);
    padding-top: 40px;
    padding-bottom: 10px;
  }

  .featured-hero-card {
    padding: 0;
    overflow: hidden;
    border-radius: 24px;
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-lg);
  }

  .hero-card-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
  }

  @media (max-width: 992px) {
    .hero-card-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .hero-image-wrapper {
    position: relative;
