---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FormRegister from '../components/FormRegister.astro';
import MapEmbed from '../components/MapEmbed.astro';

// Import ảnh Hero & Section
import heroImage from '../assets/be-boi-newton/be-boi-newton-giao-vien-huong-dan.jpg';
import spaceImage from '../assets/be-boi-newton/be-boi-newton-khong-gian-be-boi.jpg';
import supportImage from '../assets/be-boi-newton/be-boi-newton-be-tap-boi.jpg';
import registerSectionImage from '../assets/be-boi-newton/be-boi-newton-lop-hoc-boi.jpg';

// Fetch dữ liệu CMS động từ Content Collections
const courses = await getCollection('courses');
const sortedCourses = courses.sort((a, b) => a.data.order - b.data.order);

const testimonials = await getCollection('testimonials');
const sortedTestimonials = testimonials.sort((a, b) => a.data.order - b.data.order);

const faqs = await getCollection('faqs');
const sortedFaqs = faqs.sort((a, b) => a.data.order - b.data.order);

// Lấy danh sách ảnh thực tế để làm Gallery
const galleryImages = [
  { src: import('../assets/be-boi-newton/be-boi-newton-lop-hoc-boi.jpg'), alt: "Lớp học bơi nhóm nhỏ cho trẻ em tại bể bơi Newton" },
  { src: import('../assets/be-boi-newton/be-boi-newton-be-boi-co-mai-che.jpg'), alt: "Không gian bể bơi Newton có mái che kín gió" },
  { src: import('../assets/be-boi-newton/be-boi-newton-be-tap-boi.jpg'), alt: "Học viên tập nổi dưới sự kèm sát của huấn luyện viên" },
  { src: import('../assets/be-boi-newton/be-boi-newton-giao-vien-huong-dan.jpg'), alt: "Giáo viên trực tiếp xuống nước hướng dẫn học viên" },
  { src: import('../assets/be-boi-newton/be-boi-newton-hoc-vien-tap-luyen.jpg'), alt: "Học viên tự tin tập bơi sải sải dài tay" },
  { src: import('../assets/be-boi-newton/be-boi-newton-huong-dan-hoc-vien.jpg'), alt: "Hướng dẫn kỹ thuật quạt tay bơi ngửa chuẩn xác" },
  { src: import('../assets/be-boi-newton/be-boi-newton-khong-gian-be-boi.jpg'), alt: "Bể bơi Newton sạch sẽ làn nước trong mát" },
  { src: import('../assets/be-boi-newton/be-boi-newton-toan-canh-be-boi.jpg'), alt: "Toàn cảnh làn bơi chia lane tại bể bơi Newton" }
];

// Giải quyết các promise của hình ảnh trong gallery
const resolvedGallery = await Promise.all(
  galleryImages.map(async (img) => {
    const mod = await img.src;
    return { src: mod.default, alt: img.alt };
  })
);
---

<Layout 
  title="Học Bơi Tại Bể Bơi Newton Hoàng Quốc Việt Cầu Giấy | CanSwim"
  description="Lớp học bơi trẻ em và người lớn tại bể bơi Newton cuối ngõ 234 Hoàng Quốc Việt, Nghĩa Đô, Cầu Giấy. Lớp học nhóm nhỏ 1-3 học viên, giáo viên kèm sát, cam kết biết bơi."
  schemaType="LocalBusiness"
>
  <!-- SECTION 1: HERO -->
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="hero-badge">Học bơi bài bản từ cơ bản đến nâng cao</span>
        <h1 class="hero-title">
          TUYỂN SINH<br />
          <span class="gradient-text">KHÓA HỌC BƠI HÈ 2026</span>
        </h1>
        <h2 class="hero-subtitle">DẠY BƠI TRỰC TIẾP TẠI BỂ BƠI NEWTON</h2>
        
        <ul class="hero-bullets">
          <li class="bullet-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="bullet-icon"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Cam kết biết bơi đúng kỹ thuật</span>
          </li>
          <li class="bullet-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="bullet-icon"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Giáo viên giàu kinh nghiệm, chứng chỉ sư phạm</span>
          </li>
          <li class="bullet-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="bullet-icon"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Lớp học cá nhân nhóm nhỏ (tối đa 3 - 6 bé)</span>
          </li>
          <li class="bullet-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="bullet-icon"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Đối tác chính thức tổ chức lớp bơi cho cư dân Vinhomes</span>
          </li>
        </ul>

        <div class="hero-actions-block">
          <a href="#register" class="btn btn-primary">ĐĂNG KÝ TƯ VẤN MIỄN PHÍ</a>
          <a href="tel:0907992336" class="hero-hotline">
            <div class="hotline-icon-circle">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="phone-svg"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="hotline-text-block">
              <span class="hotline-label">Hotline tư vấn</span>
              <span class="hotline-num">0907 992 336</span>
            </div>
          </a>
        </div>
      </div>
      <div class="hero-media animate-wave">
        <Image src={heroImage} alt="Tuyển sinh học bơi bể bơi Newton" class="hero-img" priority width={580} height={400} quality="high" />
        <div class="hero-media-backdrop"></div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: PAIN POINT & SOLVED -->
  <section class="section-padding compare-section">
    <div class="container compare-grid">
      <!-- Pain Point Card -->
      <div class="compare-card pain-card glass-card">
        <h3 class="compare-title pain-title">CON BẠN CÓ ĐANG...</h3>
        <ul class="compare-list">
          <li class="compare-item">
            <div class="item-icon-circle cancel-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <span>Sợ nước, nhát nước, không dám xuống bể</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle cancel-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <span>Không biết nổi, quạt tay chân cuống cuồng</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle cancel-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <span>Học nhiều khóa, nhiều nơi vẫn chưa biết bơi</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle cancel-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <span>Thiếu kỹ năng sinh tồn, xử lý tình huống đuối nước</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle cancel-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <span>Xem tivi, ipad quá nhiều, lười vận động thể chất</span>
          </li>
        </ul>
      </div>

      <!-- Arrow Divider -->
      <div class="compare-divider">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow-icon-svg"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>

      <!-- Solved Card -->
      <div class="compare-card solved-card glass-card">
        <h3 class="compare-title solved-title">SAU KHÓA HỌC HỌC VIÊN CÓ THỂ:</h3>
        <ul class="compare-list">
          <li class="compare-item">
            <div class="item-icon-circle check-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Tự tin xuống nước, làm chủ hơi thở dưới sâu</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle check-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Nổi ngửa thả lỏng và bơi đúng kỹ thuật chuẩn xác</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle check-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Biết bơi thực tế, bơi bền bỉ qua nhiều vòng bể</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle check-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Nắm chắc kỹ năng phòng chống đuối nước sinh tồn</span>
          </li>
          <li class="compare-item">
            <div class="item-icon-circle check-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Yêu thích thể thao, nâng cao thể chất và chiều cao</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SECTION 3: CORE BRAND POSITION -->
  <section class="section-padding brand-position-section">
    <div class="container brand-position-grid">
      <div class="brand-text-area">
        <h2 class="section-heading-left">HƠN 15 NĂM ĐẠO TẠO BƠI LỘI</h2>
        <p class="brand-paragraph">
          <strong>CanSwim</strong> là đơn vị đào tạo bơi lội chuyên nghiệp với hơn 15 năm kinh nghiệm. Đặc biệt từ năm 2018 đến nay, CanSwim tự hào là đơn vị uy tín trực tiếp liên kết tổ chức và giảng dạy các lớp học bơi chất lượng cao cho cộng đồng cư dân Vinhomes.
        </p>
        <p class="brand-paragraph">
          Chúng tôi đã đồng hành và giúp đỡ hàng nghìn học viên mọi lứa tuổi từ sợ nước trở nên tự tin bơi lội, bơi đúng kỹ thuật sau mỗi khóa học.
        </p>
      </div>

      <div class="brand-cards-grid">
        <div class="brand-feature-card glass-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="feat-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4>15+ Kinh Nghiệm</h4>
          <p>Hơn 15 năm phát triển sư phạm bơi lội</p>
        </div>

        <div class="brand-feature-card glass-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="feat-icon"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20M4 19.5V3a1 1 0 0 1 1-1h15v20H5.5A2.5 2.5 0 0 1 4 19.5z"/></svg>
          </div>
          <h4>Giáo Trình Chuẩn</h4>
          <p>Lộ trình thiết kế khoa học theo từng học viên</p>
        </div>

        <div class="brand-feature-card glass-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="feat-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>Đội Ngũ Cao Cấp</h4>
          <p>HLV có bằng cấp quốc gia và sư phạm</p>
        </div>

        <div class="brand-feature-card glass-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="feat-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4>Thực Hành 100%</h4>
          <p>Học viên trực tiếp thực hành dưới nước mỗi ca</p>
        </div>

        <div class="brand-feature-card glass-card span-two-mobile">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="feat-icon"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <h4>Theo Sát Học Viên</h4>
          <p>Tỷ lệ nhóm nhỏ giúp giám sát và an toàn tối đa</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: LOCAL VENUE DETAILS -->
  <section class="section-padding venue-detail-section">
    <div class="container">
      <div class="section-header">
        <span class="gradient-text section-subtitle">KHÔNG GIAN HỌC TẬP HIỆN ĐẠI</span>
        <h2 class="section-title">HỌC TẠI BỂ BƠI NEWTON CÓ GÌ KHÁC?</h2>
      </div>

      <div class="venue-detail-grid">
        <div class="venue-left-content">
          <div class="venue-features-list">
            <div class="venue-feat-item">
              <div class="feat-dot"></div>
              <div>
                <h5>Bể bơi sạch sẽ, lọc nước chuẩn Châu Âu</h5>
                <p>Hệ thống lọc nước tuần hoàn liên tục không mùi clo gây hại da và tóc bé.</p>
              </div>
            </div>
            
            <div class="venue-feat-item">
              <div class="feat-dot"></div>
              <div>
                <h5>Bể bơi có mái che kín gió</h5>
                <p>Giúp học sinh và khách lẻ bơi lội an toàn bất chấp thời tiết mưa nắng.</p>
              </div>
            </div>

            <div class="venue-feat-item">
              <div class="feat-dot"></div>
              <div>
                <h5>Khu vực thay đồ tiện nghi</h5>
                <p>Có đầy đủ phòng tắm tráng, thay đồ sạch sẽ ngăn nắp cho nam và nữ.</p>
              </div>
            </div>

            <div class="venue-feat-item">
              <div class="feat-dot"></div>
              <div>
                <h5>Bảo vệ an toàn tối đa cho trẻ em</h5>
                <p>Nằm trong khuôn viên trường Newton khép kín, an ninh 24/7 chuyên nghiệp.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="venue-media-center">
          <Image src={spaceImage} alt="Không gian Bể bơi Newton" class="venue-img" width={480} height={320} quality="high" />
        </div>

        <div class="venue-right-card glass-card">
          <h4 class="card-title-highlight">HỌC VIÊN ĐƯỢC:</h4>
          <ul class="benefits-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="check-svg"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Kiểm tra trình độ đầu vào chuẩn xác</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="check-svg"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Xây dựng lộ trình học tập cá nhân phù hợp</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="check-svg"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Giáo viên trực tiếp xuống nước theo sát 100%</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="check-svg"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Điều chỉnh và sửa kỹ thuật bơi từng buổi</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: COURSES CARDS (CMS FETCH) -->
  <section class="section-padding courses-section" id="courses">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">CÁC KHÓA HỌC ĐANG TUYỂN SINH</h2>
        <p class="section-subtitle">Chương trình học bơi được chia theo nhóm trình độ và lứa tuổi, tối ưu hóa thời gian biết bơi cho học viên.</p>
      </div>

      <div class="courses-grid">
        {sortedCourses.map((course) => (
          <CourseCard course={course} />
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6: QUALITY COMMITMENT -->
  <section class="section-padding commitment-section">
    <div class="container commitment-grid">
      <div class="commitment-media">
        <Image src={supportImage} alt="Học viên chưa đạt tiếp tục được kèm tại CanSwim" class="commitment-img" width={480} height={320} quality="high" />
      </div>
      
      <div class="commitment-content">
        <span class="commitment-badge">UY TÍN HÀNG ĐẦU</span>
        <h2 class="commitment-title">HỌC CHƯA ĐẠT - TIẾP TỤC ĐƯỢC KÈM</h2>
        <p class="commitment-desc">
          CanSwim cam kết đồng hành cùng học viên cho đến khi tự tin bơi tốt. Chúng tôi hiểu mỗi học viên có tốc độ làm quen nước khác nhau, vì vậy chương trình dạy học bơi luôn linh hoạt và trách nhiệm cao nhất.
        </p>

        <h4 class="commitment-subtitle">TOÀN BỘ KHÓA HỌC BAO GỒM:</h4>
        <div class="commitment-features">
          <div class="commit-feat-box">
            <span class="commit-feat-num">15</span>
            <span class="commit-feat-text">Vé bơi theo buổi học</span>
          </div>
          <div class="commit-feat-box">
            <span class="commit-feat-icon">👤</span>
            <span class="commit-feat-text">Giáo viên kèm sát</span>
          </div>
          <div class="commit-feat-box">
            <span class="commit-feat-icon">🎯</span>
            <span class="commit-feat-text">Học viên học chậm được hỗ trợ đến khi bơi tốt</span>
          </div>
          <div class="commit-feat-box">
            <span class="commit-feat-icon">🎁</span>
            <span class="commit-feat-text">Tặng thêm 15 buổi tự tập sau khóa học</span>
          </div>
        </div>

        <div class="commitment-banner">
