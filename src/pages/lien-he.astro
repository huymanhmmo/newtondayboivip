---
import Layout from '../layouts/Layout.astro';
import FormRegister from '../components/FormRegister.astro';
import MapEmbed from '../components/MapEmbed.astro';
---

<Layout 
  title="Liên Hệ & Chỉ Đường Tới Bể Bơi Newton Hoàng Quốc Việt"
  description="Thông tin liên hệ hotline, Zalo của trung tâm dạy bơi CanSwim tại bể bơi Newton cuối ngõ 234 Hoàng Quốc Việt, Nghĩa Đô, Cầu Giấy. Bản đồ chỉ đường đi chi tiết."
  schemaType="LocalBusiness"
>
  <!-- Page Header -->
  <section class="page-header-section">
    <div class="container text-center">
      <span class="page-meta-badge">Thông tin liên hệ chính thức</span>
      <h1 class="page-title-main">LIÊN HỆ & CHỈ ĐƯỜNG</h1>
      <p class="page-desc-main">Bạn có câu hỏi hoặc muốn đăng ký học bơi? Hãy liên hệ trực tiếp với CanSwim hoặc tham khảo sơ đồ đường đi chi tiết tới bể bơi Newton Cầu Giấy dưới đây.</p>
    </div>
  </section>

  <!-- Contact & Form Section -->
  <section class="section-padding contact-main-section" id="register">
    <div class="container">
      <div class="contact-main-grid">
        <!-- Intro & Image Column -->
        <div class="contact-intro-col">
          <h2 class="section-subheading">Kênh Liên Hệ Nhanh</h2>
          <p class="intro-p">
            Đội ngũ tư vấn viên của CanSwim luôn sẵn sàng hỗ trợ giải đáp mọi thắc mắc về khóa học bơi, lịch học thử và xếp lớp học phù hợp nhất. Quý phụ huynh và học viên có thể điền thông tin đăng ký nhanh hoặc kết nối qua các kênh hỗ trợ chính thức dưới đây.
          </p>

          <div class="contact-side-image-wrapper">
            <img src="/images/be-boi-newton-khong-gian-be-boi.jpg" alt="Không gian thoáng mát tại bể bơi Newton Hoàng Quốc Việt Cầu Giấy" class="contact-side-img" width="500" height="333" loading="lazy" />
          </div>
        </div>

        <!-- Registration Form Column -->
        <div class="contact-form-col">
          <FormRegister />
        </div>
      </div>

      <!-- Contact Info Cards Grid (Horizontal Below for perfect balance) -->
      <div class="contact-cards-grid">
        <!-- Hotline Card -->
        <div class="contact-info-card glass-card">
          <div class="info-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="info-svg"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="info-card-content">
            <h3 class="card-item-title">Điện thoại Hotline</h3>
            <p><a href="tel:0907992336" class="contact-link-bold">0907.992.336</a></p>
            <span class="note-text">(Hỗ trợ cuộc gọi 24/7)</span>
          </div>
        </div>

        <!-- Zalo Card -->
        <div class="contact-info-card glass-card">
          <div class="info-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="info-svg"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div class="info-card-content">
            <h3 class="card-item-title">Chat qua Zalo</h3>
            <p><a href="http://zalo.me/0907992336" target="_blank" rel="noopener noreferrer" class="contact-link-bold">0907 992 336</a></p>
            <span class="note-text">(Tư vấn trực tuyến)</span>
          </div>
        </div>

        <!-- Fanpage Card -->
        <div class="contact-info-card glass-card">
          <div class="info-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="info-svg"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </div>
          <div class="info-card-content">
            <h3 class="card-item-title">Fanpage Facebook</h3>
            <p><a href="https://www.facebook.com/beboinewton" target="_blank" rel="noopener noreferrer" class="contact-link-bold">Bể Bơi Newton</a></p>
            <span class="note-text">(Cập nhật ảnh và tin tức)</span>
          </div>
        </div>

        <!-- Address Card -->
        <div class="contact-info-card glass-card Address-card">
          <div class="info-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="info-svg"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="info-card-content">
            <h3 class="card-item-title">Địa chỉ lớp học</h3>
            <p class="address-text">Trường Newton, lô TH2 KĐT Nam Cường, cuối ngõ 234 Hoàng Quốc Việt, Cầu Giấy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Map Section -->
  <section class="section-padding contact-map-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Bản Đồ Vị Trí & Chỉ Đường</h2>
        <p class="section-subtitle">Dùng thiết bị di động quét hoặc nhấp vào bản đồ bên dưới để mở điều hướng Google Maps dẫn đường trực tiếp.</p>
      </div>
      
      <div class="map-embed-wrapper">
        <MapEmbed height="500px" />
      </div>

      <div class="directions-guide-box">
        <h3 class="directions-title">Hướng Dẫn Di Chuyển Chi Tiết Bằng Các Phương Tiện</h3>
        <p class="intro-p">Bể bơi Newton tọa lạc tại vị trí thuận lợi ở quận Cầu Giấy, tiếp giáp quận Bắc Từ Liêm và Tây Hồ. Học viên đăng ký học bơi tại trung tâm <a href="/">CanSwim</a> có thể di chuyển đến bể bơi bằng các phương tiện sau:</p>
        
        <div class="directions-grid-two-cols">
          <div class="direction-method">
            <h4 class="method-title">Di chuyển bằng phương tiện cá nhân (Xe máy, Ô tô)</h4>
            <p class="intro-p">Học viên đi từ hướng đường Hoàng Quốc Việt rẽ vào Ngõ 234 (đối diện Đại học Điện lực). Đi thẳng khoảng 300m, qua Tòa án nhân dân quận Cầu Giấy, rẽ trái vào Khu đô thị Nam Cường. Đi tiếp đến cuối ngõ, bạn sẽ thấy cổng trường liên cấp Newton TH2, <a href="/be-boi-newton-hoang-quoc-viet/">bể bơi Newton</a> nằm ngay trong khuôn viên trường học.</p>
          </div>
          
          <div class="direction-method">
            <h4 class="method-title">Di chuyển bằng xe bus công cộng</h4>
            <p class="intro-p">Các tuyến xe bus dừng gần ngõ 234 Hoàng Quốc Việt bao gồm: xe 14, 14CT, 33, 38, 45, 53A. Sau khi xuống điểm dừng tại đường Hoàng Quốc Việt, học viên chỉ cần đi bộ vào ngõ 234 khoảng 5-7 phút là đến nơi học bơi.</p>
          </div>
        </div>

        <h3 class="directions-title">Hướng Dẫn Gửi Xe Máy Và Xe Ô Tô An Toàn</h3>
        <div class="parking-grid-two-cols">
          <div class="parking-method">
            <h4 class="method-title">Vị trí bãi đỗ xe máy tại bể bơi Newton</h4>
            <p class="intro-p">Học viên đi xe máy có thể dắt xe qua cổng bảo vệ trường Newton và gửi xe tại nhà xe chuyên dụng của bể bơi. Bãi đỗ xe rộng rãi, có mái che và có bảo vệ trông giữ an toàn.</p>
          </div>
          
          <div class="parking-method">
            <h4 class="method-title">Vị trí đỗ xe ô tô khu đô thị Nam Cường</h4>
            <p class="intro-p">Đối với phụ huynh đưa đón con bằng xe ô tô hoặc học viên tự lái xe, bạn có thể đỗ xe dọc theo các tuyến đường nội khu thông thoáng bao quanh trường Newton hoặc gửi xe tại hầm chung cư kề bên.</p>
          </div>
        </div>

        <div class="info-linking-box">
          <h3 class="directions-title">Liên Kết Các Khóa Học Liên Quan</h3>
          <p class="intro-p">Trước khi đến bể bơi, quý học viên vui lòng tham khảo trước <a href="/lich-hoc-hoc-phi-day-boi-newton/">Lịch học và học phí dạy bơi Newton</a> để nắm được mức chi phí và đăng ký ca học trống. Chúng tôi có các lớp học bơi đa dạng như <a href="/lop-hoc-boi-tre-em-be-boi-newton/">Lớp học bơi trẻ em bể bơi Newton</a> và <a href="/hoc-boi-nguoi-lon-be-boi-newton/">Lớp học bơi người lớn bể bơi Newton</a> nhằm phục vụ mọi thành viên trong gia đình bạn.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Contact Main Grid */
  .contact-main-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 50px;
    align-items: center;
    margin-bottom: 40px;
  }

  .section-subheading {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .intro-p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 30px;
  }

  .contact-side-image-wrapper {
    margin-bottom: 0;
  }

  .contact-side-img {
    width: 100%;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
  }

  /* Contact Cards Grid */
  .contact-cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 50px;
  }

  .contact-info-card {
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 15px;
    height: 100%;
    border-radius: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    transition: all var(--transition-normal);
  }

  .contact-info-card:hover {
    transform: translateY(-5px);
    border-color: rgba(0, 102, 170, 0.25);
    box-shadow: var(--shadow-lg);
  }

  .info-card-icon {
    width: 48px;
    height: 48px;
    background-color: var(--color-primary-glare);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-svg {
    width: 20px;
    height: 20px;
  }

  .card-item-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .contact-info-card p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin: 0;
  }

  .note-text {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 4px;
  }

  .address-text {
    font-size: 0.82rem !important;
    line-height: 1.5 !important;
  }

  .contact-link-bold {
    font-weight: 700;
    color: var(--color-primary);
  }

  .contact-link-bold:hover {
    text-decoration: underline;
  }

  /* Directions guide layout */
  .directions-guide-box {
    margin-top: 40px;
    background-color: var(--color-bg-alt);
    padding: 40px;
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
  }

  .directions-title {
    font-size: 1.4rem;
    color: var(--color-primary);
    margin-top: 30px;
    margin-bottom: 15px;
    border-bottom: 2px solid var(--color-primary-glare);
    padding-bottom: 8px;
  }

  .directions-title:first-of-type {
    margin-top: 0;
  }

  .directions-grid-two-cols, .parking-grid-two-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 20px;
  }

  .method-title {
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .map-embed-wrapper {
    box-shadow: var(--shadow-md);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .contact-main-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact-cards-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .directions-grid-two-cols, .parking-grid-two-cols {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 600px) {
    .contact-cards-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
