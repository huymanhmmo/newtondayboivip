---
import Layout from '../layouts/Layout.astro';
import FormRegister from '../components/FormRegister.astro';
---

<Layout 
  title="Lớp Bơi Tập Thể Bể Bơi Newton Cầu Giấy Chỉ 1.5tr | CanSwim"
  description="Đăng ký lớp bơi tập thể CanSwim tại bể bơi Newton Hoàng Quốc Việt Cầu Giấy. Khóa học bơi giá rẻ chỉ 1.5 triệu trọn gói đã gồm vé bơi, giáo viên kèm sát."
  schemaType="LocalBusiness"
>
  <!-- Page Header -->
  <section class="page-header-section kids-theme">
    <div class="container text-center">
      <span class="page-meta-badge">Khóa học tiết kiệm</span>
      <h1 class="page-title-main">LỚP BƠI TẬP THỂ TẠI BỂ BƠI NEWTON</h1>
      <p class="page-desc-main">Học bơi bài bản – chi phí hợp lý – dễ đăng ký tại Cầu Giấy. Khóa học 10 buổi trọn gói chỉ 1.500.000Đ đã bao gồm vé bể.</p>
    </div>
  </section>

  <!-- Service Details -->
  <section class="section-padding group-benefits-section">
    <div class="container benefits-grid-split">
      <div class="benefits-text">
        <h2 class="section-subheading">Khóa Học Bơi Tập Thể CanSwim Chi Phí Siêu Tiết Kiệm</h2>
        <p class="intro-p">
          Khóa học bơi tập thể CanSwim tại <a href="/be-boi-newton-hoang-quoc-viet/">Bể bơi Newton Cầu Giấy</a> là giải pháp hoàn hảo cho học sinh, sinh viên và người lớn mới bắt đầu học bơi với mức chi phí cực kỳ tối ưu, chỉ <strong>1.500.000Đ / khóa</strong>. Mức phí này là trọn gói và đã bao gồm vé vào cửa bể.
        </p>

        <div class="benefits-bullets-box">
          <div class="benefit-bullet-item">
            <span class="bullet-check">✓</span>
            <div>
              <strong>10 buổi học chất lượng cùng HLV:</strong> Học viên được đào tạo bài bản kỹ thuật bơi ếch nền tảng từ HLV chuyên nghiệp, giàu kinh nghiệm của <a href="/">CanSwim</a>.
            </div>
          </div>
          
          <div class="benefit-bullet-item">
            <span class="bullet-check">✓</span>
            <div>
              <strong>Đã bao gồm 10 vé vào cửa:</strong> Bạn không cần phải mua thêm bất kỳ vé bơi nào trong suốt thời gian diễn ra khóa học.
            </div>
          </div>

          <div class="benefit-bullet-item">
            <span class="bullet-check">✓</span>
            <div>
              <strong>Sĩ số giới hạn 10 học viên / ca:</strong> Đảm bảo huấn luyện viên có thể theo sát hướng dẫn chi tiết và sửa lỗi cho từng học viên.
            </div>
          </div>

          <div class="benefit-bullet-item">
            <span class="bullet-check">✓</span>
            <div>
              <strong>Dành cho học viên từ 10 tuổi trở lên:</strong> Thiết kế lớp tập trung, kỷ luật tự lập cao cho học sinh, sinh viên và người lớn.
            </div>
          </div>
        </div>
      </div>

      <div class="benefits-media">
        <img src="/images/tuyen-sinh/lop-boi-tap-the-1t5.png" alt="Lớp học bơi tập thể CanSwim 1.5 triệu" class="group-benefit-img" width="500" height="355" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Learning Process -->
  <section class="section-padding learning-process-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Lộ Trình Học Bơi 10 Buổi Hệ Tập Thể</h2>
        <p class="section-subtitle">Giáo trình đào tạo khoa học từ cơ bản đến hoàn thiện kỹ thuật bơi và kỹ năng sinh tồn dưới nước.</p>
      </div>

      <div class="process-steps-container">
        <!-- Step 1 -->
        <div class="process-step-card glass-card">
          <span class="step-badge">Buổi 1 - 2</span>
          <h4 class="step-card-title">Khởi động & Làm quen nước</h4>
          <p>Tập thở nước đúng cách (hít hơi miệng, thở mũi dưới nước), kỹ thuật thả nổi ngửa cơ bản và đứng nước thăng bằng để giải tỏa sợ nước.</p>
        </div>

        <!-- Step 2 -->
        <div class="process-step-card glass-card">
          <span class="step-badge">Buổi 3 - 5</span>
          <h4 class="step-card-title">Đạp chân & Quạt tay ếch</h4>
          <p>Rèn luyện động tác đạp chân ếch chuẩn xác tạo lực đẩy lướt nước và động tác quạt tay đẩy nước hỗ trợ nhấc đầu lấy hơi.</p>
        </div>

        <!-- Step 3 -->
        <div class="process-step-card glass-card">
          <span class="step-badge">Buổi 6 - 8</span>
          <h4 class="step-card-title">Phối hợp động tác & Tự bơi</h4>
          <p>Phối hợp nhịp nhàng chuỗi động tác: Tay quạt đầu lên lấy hơi - chân đạp lướt nước. Thực hành bơi cự ly ngắn từ 5m đến 10m.</p>
        </div>

        <!-- Step 4 -->
        <div class="process-step-card glass-card">
          <span class="step-badge">Buổi 9 - 10</span>
          <h4 class="step-card-title">Hoàn thiện bơi & Sinh tồn</h4>
          <p>Tăng cự ly bơi lên 15m - 25m bể tiêu chuẩn, kiểm tra đầu ra bơi độc lập và trang bị kỹ năng an toàn sinh tồn xử lý chuột rút dưới nước.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing and Comparison -->
  <section class="section-padding pricing-comparison-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">So Sánh Lớp Bơi Tập Thể và Lớp Bơi Kèm Riêng</h2>
        <p class="section-subtitle">Giúp học viên chọn lựa hình thức học tập phù hợp nhất với nhu cầu cá nhân.</p>
      </div>

      <div class="canswim-table-wrapper">
        <table class="canswim-table">
          <thead>
            <tr>
              <th>Tiêu chí so sánh</th>
              <th>Lớp bơi tập thể CanSwim</th>
              <th>Lớp bơi nhóm nhỏ (Kèm riêng)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Mức học phí</strong></td>
              <td>1.500.000đ / khóa (Tiết kiệm tối đa)</td>
              <td>Từ 2.500.000đ - 6.000.000đ / khóa</td>
            </tr>
            <tr>
              <td><strong>Sĩ số học viên</strong></td>
              <td>Tối đa 10 học viên / 1 HLV</td>
              <td>Nhóm nhỏ 1-3 hoặc 4-6 học viên / 1 HLV</td>
            </tr>
            <tr>
              <td><strong>Số lượng buổi học</strong></td>
              <td>10 buổi thực hành</td>
              <td>15 buổi thực hành bài bản</td>
            </tr>
            <tr>
              <td><strong>Quyền lợi vé bơi</strong></td>
              <td>Đã bao gồm 10 vé bơi ngày học</td>
              <td>Bao gồm 15 vé ngày học + Tặng 15 vé tự bơi</td>
            </tr>
            <tr>
              <td><strong>Độ tuổi áp dụng</strong></td>
              <td>Chỉ nhận từ 10 tuổi trở lên</td>
              <td>Từ 5 tuổi trở lên (Trẻ em và người lớn)</td>
            </tr>
            <tr>
              <td><strong>Tính linh hoạt lịch</strong></td>
              <td>Học theo ca cố định, không học bù</td>
              <td>Lịch học linh động, hỗ trợ học bù miễn phí</td>
            </tr>
            <tr>
              <td><strong>Cam kết đầu ra</strong></td>
              <td>HLV theo sát chỉnh sửa trong 10 buổi</td>
              <td>Hỗ trợ dạy kèm thêm miễn phí nếu chậm biết bơi</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Target Audience and Location Info -->
  <section class="section-padding audience-location-section">
    <div class="container location-grid">
      <div class="location-content">
        <h2 class="section-subheading">Đối Tượng Phù Hợp & Vị Trí Học Bơi Thuận Tiện</h2>
        <p class="intro-p">
          Khóa bơi tập thể 1.5 triệu đồng của CanSwim được thiết kế hướng tới các nhóm học viên:
        </p>
        <ul class="audience-list">
          <li><strong>Học sinh & Sinh viên Cầu Giấy:</strong> Mong muốn học bơi rèn luyện thể chất với mức chi phí rẻ, hợp lý nhất.</li>
          <li><strong>Nhóm bạn hoặc gia đình:</strong> Đi học bơi cùng nhau theo nhóm cố định để tăng thêm niềm vui và động lực.</li>
          <li><strong>Người lớn mới bắt đầu:</strong> Muốn học kỹ thuật bơi ếch bài bản từ con số 0 dưới sự chỉ dẫn trực tiếp của HLV.</li>
          <li><strong>Nhân viên văn phòng:</strong> Rèn luyện thể thao sau giờ làm việc, cải thiện tình trạng vai gáy và cột sống do ngồi nhiều.</li>
        </ul>
        <p class="intro-p" style="margin-top: 20px;">
          Lớp học tổ chức tại <a href="/be-boi-newton-hoang-quoc-viet/">Bể bơi Newton</a>, ngõ 234 Hoàng Quốc Việt, Cầu Giấy. Bể bơi bốn mùa nước ấm (29-31 độ C) có mái che rộng rãi, sử dụng công nghệ lọc nước muối điện phân không hóa chất, bảo vệ da và mắt tối đa.
        </p>
      </div>

      <div class="location-media">
        <img src="/images/tuyen-sinh/lop-boi-tap-the-gia-re.png" alt="Sĩ số lớp bơi tập thể Newton" class="location-side-img" width="500" height="355" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FAQ Section for Students -->
  <section class="section-padding faq-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Câu Hỏi Thường Gặp Về Lớp Học Bơi Tập Thể</h2>
        <p class="section-subtitle">Giải đáp thắc mắc phổ biến của học viên khi đăng ký lớp học bơi tại bể bơi Newton Cầu Giấy.</p>
      </div>

      <div class="faq-accordion-box">
        <div class="accordion">
          <div class="accordion-header">
            <span>Chưa biết bơi chút nào có đăng ký học lớp tập thể được không?</span>
            <span class="accordion-icon">▼</span>
          </div>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              Hoàn toàn được. Khóa học bơi tập thể được thiết kế dành riêng cho người mới bắt đầu hoặc học viên chưa tự tin dưới nước. HLV sẽ hướng dẫn chi tiết từ các kỹ thuật thở nước, nổi nước cơ bản nhất nên bạn không cần phải lo lắng.
            </div>
          </div>
        </div>

        <div class="accordion">
          <div class="accordion-header">
            <span>Học phí 1.5 triệu đã bao gồm vé vào cửa bể bơi Newton chưa?</span>
            <span class="accordion-icon">▼</span>
          </div>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              Đã bao gồm đầy đủ. Mức học phí 1.500.000đ là trọn gói cho 10 buổi học, học viên không phải mua thêm vé bơi hay đóng thêm bất kỳ phụ phí nào khác trong suốt khóa học.
            </div>
          </div>
        </div>

        <div class="accordion">
          <div class="accordion-header">
            <span>Lớp tập thể có áp dụng chính sách học bù nếu nghỉ học không?</span>
            <span class="accordion-icon">▼</span>
          </div>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              Không áp dụng. Do lớp học bơi tập thể hoạt động theo ca cố định và có giáo trình tiến độ chung của cả lớp, học viên tự ý nghỉ học sẽ không được sắp xếp học bù ca khác. Hãy cố gắng đi học đầy đủ để đảm bảo tiếp thu trọn vẹn lộ trình kỹ thuật.
            </div>
          </div>
        </div>

        <div class="accordion">
          <div class="accordion-header">
            <span>Có chương trình tặng thêm lượt tự bơi sau khi kết thúc khóa học không?</span>
            <span class="accordion-icon">▼</span>
          </div>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              Không áp dụng. Gói bơi tập thể giá rẻ chỉ bao gồm đúng 10 vé bơi cho 10 buổi học thực hành, không đi kèm chính sách tặng thêm vé tự bơi tự do sau khóa học như các khóa kèm riêng nhóm nhỏ tiêu chuẩn.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Register Form Placement -->
  <section class="section-padding register-callout-section" id="register-form">
    <div class="container register-split-container">
      <div class="register-image-box">
        <img src="/images/tuyen-sinh/lop-boi-tap-the-1t5.png" alt="Đăng ký lớp bơi tập thể Newton Cầu Giấy" class="register-side-img" width="580" height="400" loading="lazy" />
      </div>
      <div class="register-form-box">
        <FormRegister 
          title="ĐĂNG KÝ GIỮ CHỖ LỚP BƠI TẬP THỂ"
          subtitle="Sĩ số mỗi ca học bơi tập thể giới hạn tối đa chỉ 10 học viên. Để lại thông tin để giữ chỗ ngay hôm nay!"
        />
      </div>
    </div>
  </section>

  <!-- HOTLINE CTA STRIP -->
  <section class="hotline-cta-strip">
    <div class="container hotline-cta-container">
      <div class="hotline-cta-text">
        <span class="hotline-cta-label">📞 Liên hệ đăng ký & tư vấn miễn phí</span>
        <span class="hotline-cta-number">0907 992 336</span>
      </div>
      <div class="hotline-cta-actions">
        <a href="tel:0907992336" class="btn btn-primary btn-hotline-call">GỌI NGAY</a>
        <a href="http://zalo.me/0907992336" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-hotline-zalo">CHAT ZALO</a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Accordion Toggle
    const accordions = document.querySelectorAll('.accordion');
    accordions.forEach(accordion => {
      const header = accordion.querySelector('.accordion-header');
      if (header) {
        header.addEventListener('click', () => {
          accordion.classList.toggle('open');
        });
      }
    });
  });
</script>

<style>
  /* Benefits split */
  .benefits-grid-split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .section-subheading {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .intro-p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 25px;
  }

  .benefits-bullets-box {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .benefit-bullet-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .bullet-check {
    width: 24px;
    height: 24px;
    background-color: var(--color-primary-glare);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .benefit-bullet-item div {
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--color-text);
  }

  .group-benefit-img {
    width: 100%;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
  }

  /* Process steps */
  .learning-process-section {
    background-color: var(--color-bg-alt);
  }

  .process-steps-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }

  .process-step-card {
    background-color: var(--color-white);
    padding: 30px 24px;
    position: relative;
  }

  .step-badge {
    position: absolute;
    top: -12px;
    left: 24px;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4px 14px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    box-shadow: 0 4px 8px rgba(0, 102, 170, 0.2);
  }

  .step-card-title {
    font-size: 1.15rem;
    color: var(--color-text);
    margin-top: 8px;
    margin-bottom: 12px;
  }

  .process-step-card p {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Location Grid */
  .location-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .audience-list {
    list-style: none;
    margin-top: 15px;
  }

  .audience-list li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .audience-list li::before {
    content: '🏊';
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.9rem;
  }

  .location-side-img {
    width: 100%;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
  }

  /* FAQ Accordion Box styling */
  .faq-accordion-box {
    max-width: 800px;
    margin: 40px auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  @media (max-width: 1024px) {
    .benefits-grid-split {
      grid-template-columns: 1fr;
      gap: 35px;
    }

    .benefits-media {
      max-width: 500px;
      margin: 0 auto;
      width: 100%;
    }

    .location-grid {
      grid-template-columns: 1fr;
      gap: 35px;
    }

    .location-media {
      max-width: 500px;
      margin: 0 auto;
      width: 100%;
    }
  }
</style>
