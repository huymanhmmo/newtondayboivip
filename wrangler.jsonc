{
	"compatibility_date": "2026-05-30",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "newtondayboivip",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"send_email": [
		{
			"name": "SEND_EMAIL"
		}
	],
	"observability": {
		"enabled": true
	}
}